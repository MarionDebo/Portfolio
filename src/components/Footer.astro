---
// Real owner links (already in the repo). Swap if these ever change.
const LINKEDIN = 'https://www.linkedin.com/in/marion-debonnaire/';
const GITHUB = 'https://github.com/MarionDebo';
---

<footer class="footer">
  <div class="footer-inner">
    <p class="footer-eyebrow">LET'S TALK</p>
    <h2 class="footer-title">Building something AI-native?</h2>

    <a href={LINKEDIN} target="_blank" rel="noopener noreferrer" class="footer-cta">
      Get in touch →
    </a>

    <div class="footer-social">
      <a href={LINKEDIN} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5ZM3 9h4v12H3V9Zm6 0h3.84v1.64h.05c.53-1 1.84-2.06 3.79-2.06 4.05 0 4.8 2.67 4.8 6.14V21h-4v-5.4c0-1.29-.02-2.95-1.8-2.95-1.8 0-2.08 1.4-2.08 2.85V21H9V9Z"/></svg>
      </a>
      <a href={GITHUB} target="_blank" rel="noopener noreferrer" aria-label="GitHub">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.85 9.73.5.1.68-.22.68-.49 0-.24-.01-.87-.01-1.71-2.79.62-3.38-1.37-3.38-1.37-.45-1.18-1.11-1.5-1.11-1.5-.91-.64.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.36-2.22-.26-4.56-1.14-4.56-5.05 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.27 2.75 1.05a9.34 9.34 0 0 1 5 0c1.91-1.32 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.92-2.34 4.78-4.57 5.04.36.32.68.94.68 1.9 0 1.37-.01 2.48-.01 2.82 0 .27.18.6.69.49A10.26 10.26 0 0 0 22 12.25C22 6.58 17.52 2 12 2Z"/></svg>
      </a>
    </div>

    <p class="footer-signoff">Made with love, caffeine, and my buddy Claude</p>
  </div>
</footer>

<style>
.footer {
  background: var(--color-dark);
  color: var(--color-dark-text);
}

.footer-inner {
  max-width: var(--max-content);
  margin: 0 auto;
  padding: 96px var(--gutter);
  text-align: center;
}

.footer-eyebrow {
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--color-dark-meta);
  margin: 0 0 24px;
}

.footer-title {
  font-size: 54px;
  font-weight: 600;
  letter-spacing: -0.025em;
  color: #fff;
  margin: 0 0 28px;
}

.footer-cta {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: var(--color-accent);
  color: #fff;
  font-family: var(--font-mono);
  font-size: 14px;
  padding: 15px 30px;
  border-radius: var(--radius-pill);
  transition: background 200ms ease, transform 200ms ease;
}
.footer-cta:hover { background: #5a3de0; transform: translateY(-1px); }

.footer-social {
  display: flex;
  justify-content: center;
  gap: 16px;
  margin-top: 40px;
}
.footer-social a {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  border: 1px solid rgba(244, 242, 238, 0.2);
  color: var(--color-dark-text);
  transition: background 200ms ease, border-color 200ms ease, color 200ms ease;
}
.footer-social a:hover {
  background: var(--color-accent);
  border-color: var(--color-accent);
  color: #fff;
}

.footer-signoff {
  font-family: var(--font-mono);
  font-size: 13px;
  color: var(--color-dark-meta-2);
  letter-spacing: 0.04em;
  margin: 36px 0 0;
}

@media (max-width: 640px) {
  .footer-inner { padding: 64px var(--gutter); }
  .footer-title { font-size: 36px; }
}
</style>
