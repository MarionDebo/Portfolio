---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-left">
      <a href="/" class="footer-logo" aria-label="Home">
        <span class="logo-mark">M<span class="logo-dot">·</span>D</span>
      </a>
      <p class="footer-tagline text-muted">
        Product Manager · AI-native Analytics · B2B SaaS
      </p>
    </div>

    <nav class="footer-nav" aria-label="Footer navigation">
      <a href="/ai-expertise">AI</a>
      <a href="/portfolio">Work</a>
      <a href="/my-story">Story</a>
      <a href="mailto:hello@mariondupont.com">Contact</a>
    </nav>

    <div class="footer-social">
      <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <a href="https://github.com" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <p class="text-muted" style="font-size: var(--text-xs);">
        © {year} Marion Dupont. Built with Astro.
      </p>
    </div>
  </div>
</footer>

<style>
.footer {
  border-top: 1.5px solid var(--glass-border);
  background: rgba(255,255,255,0.42);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  padding-top: var(--space-12);
}

.footer-inner {
  display: grid;
  grid-template-columns: 1fr auto auto;
  align-items: start;
  gap: var(--space-12);
}

.footer-logo {
  display: flex;
  align-items: center;
  margin-bottom: var(--space-3);
  text-decoration: none;
}

.logo-mark {
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 1.05rem;
  letter-spacing: 0.09em;
  color: var(--color-text);
}

.logo-dot { color: var(--color-accent); }

.footer-tagline { font-size: var(--text-sm); }

.footer-nav {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.footer-nav a {
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-text-muted);
  transition: color var(--transition);
}

.footer-nav a:hover { color: var(--color-text); }

.footer-social {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.footer-social a {
  color: var(--color-text-muted);
  transition: color var(--transition);
}

.footer-social a:hover { color: var(--color-accent); }

.footer-bottom {
  margin-top: var(--space-8);
  padding-block: var(--space-4);
  border-top: 1px solid var(--color-border-soft);
}

@media (max-width: 640px) {
  .footer-inner {
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }
  .footer-social { flex-direction: row; }
}
</style>
