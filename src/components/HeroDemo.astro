---
// Signature hero moment: a faux conversational-analytics panel.
// Client island — the typing → analyzing → answer sequence runs in the browser.
---

<div class="demo">
  <div class="demo-bar">
    <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
    <div class="demo-label">ask · analytics</div>
  </div>

  <div class="demo-body">
    <!-- user question (typed) -->
    <div class="ask-row">
      <div class="ask-bubble">
        <span id="ask-text"></span><span class="caret"></span>
      </div>
    </div>

    <!-- analyzing indicator -->
    <div id="ai-thinking" class="ai-row thinking" hidden>
      <div class="ai-avatar">AI</div>
      <div class="thinking-bubble">
        <span class="thinking-label">Analyzing</span>
        <span class="bdot" style="animation-delay:0s"></span>
        <span class="bdot" style="animation-delay:0.18s"></span>
        <span class="bdot" style="animation-delay:0.36s"></span>
      </div>
    </div>

    <!-- answer + chart -->
    <div id="ai-answer" class="ai-row answer" hidden>
      <div class="ai-avatar">AI</div>
      <div class="answer-body">
        <p class="answer-text">Revenue grew <strong>+18%</strong> QoQ, led by the EMEA segment. Here's the monthly trend:</p>
        <div class="chart">
          <div class="chart-plot">
            <div class="gridlines" aria-hidden="true">
              <div class="grid-dashed"></div>
              <div class="grid-dashed"></div>
              <div class="grid-dashed"></div>
              <div class="grid-base"></div>
            </div>
            <div class="bars">
              <div style="height:40%;background:#C9B8F9"></div>
              <div style="height:56%;background:#B097F3"></div>
              <div style="height:48%;background:#C9B8F9"></div>
              <div style="height:70%;background:#9B79F1"></div>
              <div style="height:84%;background:#7A52EC"></div>
              <div style="height:100%;background:#6C4DF6"></div>
            </div>
          </div>
          <div class="months">
            <div>Jan</div><div>Feb</div><div>Mar</div><div>Apr</div><div>May</div><div class="hot">Jun</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
.demo {
  border-radius: 18px;
  overflow: hidden;
  border: 1px solid rgba(0, 0, 0, 0.07);
  box-shadow: 0 36px 64px -30px rgba(50, 30, 110, 0.42);
  background: #fff;
}
.demo-bar {
  height: 38px;
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 0 14px;
  background: #F4F2F7;
  border-bottom: 1px solid rgba(0, 0, 0, 0.05);
}
.dot { width: 10px; height: 10px; border-radius: 50%; }
.dot.red { background: var(--dot-red); }
.dot.yellow { background: var(--dot-yellow); }
.dot.green { background: var(--dot-green); }
.demo-label { margin-left: 10px; font-family: var(--font-mono); font-size: 10px; color: #9a93a8; }

.demo-body { padding: 22px 22px 26px; min-height: 236px; }

.ask-row { display: flex; justify-content: flex-end; margin-bottom: 16px; }
.ask-bubble {
  background: var(--color-accent);
  color: #fff;
  font-size: 14.5px;
  line-height: 1.45;
  padding: 11px 15px;
  border-radius: 14px 14px 4px 14px;
  max-width: 82%;
}
.caret {
  display: inline-block;
  width: 2px;
  height: 15px;
  background: #fff;
  margin-left: 1px;
  vertical-align: -2px;
  animation: aiCaret 1s step-end infinite;
}

.ai-row { display: flex; gap: 10px; }
.ai-row.thinking { align-items: center; animation: aiRise 300ms ease both; }
.ai-row.answer { align-items: flex-start; animation: aiRise 420ms ease both; }
.ai-row[hidden] { display: none; }
.ai-avatar {
  width: 26px;
  height: 26px;
  border-radius: 8px;
  background: var(--color-bg-lilac);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 12px;
  color: var(--color-accent);
}

.thinking-bubble {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: #F4F2F7;
  border-radius: 12px 12px 12px 4px;
  padding: 12px 15px;
}
.thinking-label { font-family: var(--font-display); font-size: 13px; color: #8a8594; margin-right: 3px; }
.bdot { width: 6px; height: 6px; border-radius: 50%; background: #9B79F1; animation: aiDot 1.2s infinite; }

.answer-body { flex: 1; }
.answer-text { font-size: 14.5px; line-height: 1.5; color: var(--color-body); margin: 0 0 14px; }
.answer-text strong { color: var(--color-accent); }

.chart { background: #FAF9FF; border-radius: 12px; border: 1px solid rgba(var(--color-accent-rgb), 0.14); padding: 14px 14px 0; }
.chart-plot { position: relative; height: 138px; }
.gridlines { position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: space-between; }
.grid-dashed { border-top: 1px dashed rgba(var(--color-accent-rgb), 0.14); }
.grid-base { border-top: 1px solid rgba(var(--color-accent-rgb), 0.28); }
.bars { position: absolute; inset: 0; display: flex; align-items: flex-end; gap: 10px; }
.bars > div { flex: 1; border-radius: 4px 4px 0 0; }
.months { display: flex; gap: 10px; padding: 7px 0 11px; }
.months > div { flex: 1; text-align: center; font-family: var(--font-mono); font-size: 9px; color: #9a93a8; }
.months .hot { color: var(--color-accent); }
</style>

<script>
  const askEl = document.getElementById('ask-text');
  const thinkEl = document.getElementById('ai-thinking');
  const answerEl = document.getElementById('ai-answer');

  if (askEl && thinkEl && answerEl) {
    const full = 'How did revenue trend last quarter?';
    let i = 0;
    let thinkT: number, answerT: number;

    const typer = window.setInterval(() => {
      i++;
      askEl.textContent = full.slice(0, i);
      if (i >= full.length) {
        window.clearInterval(typer);
        thinkT = window.setTimeout(() => { thinkEl.hidden = false; }, 450);
        answerT = window.setTimeout(() => {
          thinkEl.hidden = true;
          answerEl.hidden = false;
        }, 2150);
      }
    }, 55);

    // Clean up if the island is torn down (e.g. Astro view transitions)
    document.addEventListener('astro:before-swap', () => {
      window.clearInterval(typer);
      window.clearTimeout(thinkT);
      window.clearTimeout(answerT);
    }, { once: true });
  }
</script>
