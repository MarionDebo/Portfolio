---
const pathname = Astro.url.pathname;

const links = [
  { href: '/', label: 'Home' },
  { href: '/ai-expertise', label: 'AI Expertise' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/my-story', label: 'My Story' },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header class="nav-header">
  <nav class="container nav-inner" aria-label="Main navigation">
    <a href="/" class="nav-logo" aria-label="Home">
      <span class="logo-mark">M</span>
      <span class="logo-text">Marion</span>
    </a>

    <ul class="nav-links" role="list">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class:list={['nav-link', { active: isActive(link.href) }]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <a href="mailto:hello@marionpm.com" class="btn btn-primary btn-sm nav-cta">
      Get in touch
    </a>

    <button class="nav-burger" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </nav>
</header>

<style>
.nav-header {
  position: sticky;
  top: 0;
  z-index: 100;
  height: var(--nav-height);
  background: rgba(10, 10, 15, 0.85);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--color-border);
}

.nav-inner {
  display: flex;
  align-items: center;
  height: 100%;
  gap: var(--space-8);
}

.nav-logo {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  flex-shrink: 0;
}

.logo-mark {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-accent-grad);
  border-radius: var(--radius-sm);
  font-weight: 700;
  font-size: var(--text-sm);
  color: #fff;
}

.logo-text {
  font-weight: 600;
  font-size: var(--text-sm);
  letter-spacing: -0.01em;
}

.nav-links {
  display: flex;
  list-style: none;
  gap: var(--space-1);
  margin-left: auto;
}

.nav-link {
  padding: var(--space-2) var(--space-3);
  border-radius: var(--radius-sm);
  font-size: var(--text-sm);
  font-weight: 450;
  color: var(--color-text-muted);
  transition: color var(--transition), background var(--transition);
}

.nav-link:hover {
  color: var(--color-text);
  background: rgba(255,255,255,0.05);
}

.nav-link.active {
  color: var(--color-text);
  background: rgba(255,255,255,0.07);
}

.btn-sm {
  padding: 0.45rem 1rem;
  font-size: var(--text-xs);
  margin-left: var(--space-4);
}

.nav-burger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  padding: var(--space-2);
  margin-left: auto;
}

.nav-burger span {
  display: block;
  width: 20px;
  height: 2px;
  background: var(--color-text);
  border-radius: 2px;
  transition: all var(--transition);
}

@media (max-width: 768px) {
  .nav-links, .nav-cta { display: none; }
  .nav-burger { display: flex; }
}
</style>

<script>
  const burger = document.querySelector('.nav-burger') as HTMLButtonElement;
  const links  = document.querySelector('.nav-links') as HTMLElement;
  const cta    = document.querySelector('.nav-cta') as HTMLElement;

  burger?.addEventListener('click', () => {
    const expanded = burger.getAttribute('aria-expanded') === 'true';
    burger.setAttribute('aria-expanded', String(!expanded));
    links?.classList.toggle('mobile-open');
    cta?.classList.toggle('mobile-open');
  });
</script>

<style is:global>
@media (max-width: 768px) {
  .nav-links.mobile-open {
    display: flex;
    flex-direction: column;
    position: fixed;
    top: var(--nav-height);
    left: 0; right: 0;
    background: var(--color-bg-surface);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-4);
    gap: var(--space-1);
    z-index: 99;
  }

  .nav-cta.mobile-open {
    display: inline-flex;
    margin: 0 var(--space-4) var(--space-4);
    position: fixed;
    top: calc(var(--nav-height) + 220px);
    left: 0; right: 0;
    z-index: 99;
    justify-content: center;
  }
}
</style>
