---
const pathname = Astro.url.pathname;

const links = [
  { href: '/work',          label: 'Work' },
  { href: '/ai-expertise',  label: 'AI Expertise' },
  { href: '/my-story',      label: 'Story' },
];

function isActive(href: string) {
  if (href === '#') return false;
  return pathname === href || pathname.startsWith(href + '/');
}
---

<header class="nav-header">
  <div id="hero-nav" class="nav-pill">
    <a href="/" class="nav-wordmark">Marion Débonnaire</a>

    <nav class="nav-links" aria-label="Main navigation">
      {links.map(link => (
        <a
          href={link.href}
          class:list={['nav-link', { active: isActive(link.href) }]}
          aria-current={isActive(link.href) ? 'page' : undefined}
        >{link.label}</a>
      ))}
    </nav>

    <button class="nav-burger" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<style>
.nav-header {
  position: sticky;
  top: 0;
  z-index: 50;
  padding: 18px var(--gutter) 0;
}

.nav-pill {
  max-width: var(--max-nav);
  margin: 0 auto;
  border-radius: var(--radius-pill);
  padding: 12px 16px 12px 26px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 1px solid transparent;
  background: transparent;
  box-shadow: none;
  transition: background 300ms ease, box-shadow 300ms ease, border-color 300ms ease;
}

/* Frosted-glass state once scrolled past the top sentinel */
.nav-pill.glassy {
  background: rgba(255, 255, 255, 0.66);
  backdrop-filter: blur(16px) saturate(1.4);
  -webkit-backdrop-filter: blur(16px) saturate(1.4);
  border-color: rgba(255, 255, 255, 0.7);
  box-shadow: var(--shadow-nav);
}

.nav-wordmark {
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 18px;
  letter-spacing: -0.01em;
  color: var(--color-ink);
}

.nav-links {
  display: flex;
  align-items: center;
  gap: 32px;
  font-family: var(--font-display);
  font-size: 15px;
  font-weight: 500;
  color: var(--color-body-soft);
}

.nav-link { color: inherit; transition: color 200ms ease; }
.nav-link:hover { color: var(--color-ink); }
.nav-link.active { color: var(--color-accent); }

/* Burger — hidden on desktop */
.nav-burger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  padding: 6px;
}
.nav-burger span {
  display: block;
  width: 22px;
  height: 2px;
  background: var(--color-ink);
  border-radius: 2px;
  transition: transform 200ms ease, opacity 200ms ease;
}
.nav-burger[aria-expanded='true'] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.nav-burger[aria-expanded='true'] span:nth-child(2) { opacity: 0; }
.nav-burger[aria-expanded='true'] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

@media (max-width: 760px) {
  .nav-burger { display: flex; }
  .nav-links {
    position: absolute;
    top: 72px;
    left: var(--gutter);
    right: var(--gutter);
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
    padding: 16px 20px;
    border-radius: var(--radius-card);
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(16px) saturate(1.4);
    -webkit-backdrop-filter: blur(16px) saturate(1.4);
    box-shadow: var(--shadow-nav);
    transform-origin: top;
    opacity: 0;
    transform: scaleY(0.96) translateY(-6px);
    pointer-events: none;
    transition: opacity 180ms ease, transform 180ms ease;
  }
  .nav-links.mobile-open {
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }
  .nav-link { padding: 8px 0; font-size: 17px; }
}
</style>

<script>
  // Glass-on-scroll: transparent at the top, frosted once the top sentinel
  // leaves the viewport. Robust to any scroll container (capture-phase listener
  // + IntersectionObserver), per the design reference.
  const pill = document.getElementById('hero-nav');
  const sentinel = document.getElementById('nav-top-sentinel');

  if (pill) {
    const apply = (glassy: boolean) => pill.classList.toggle('glassy', glassy);

    const check = () => {
      if (!sentinel) return;
      apply(sentinel.getBoundingClientRect().top < -4);
    };

    window.addEventListener('scroll', check, { passive: true, capture: true });

    if (sentinel && 'IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        entries => entries.forEach(e => apply(!e.isIntersecting)),
        { threshold: 0 }
      );
      io.observe(sentinel);
    }
    check();
  }

  // Mobile burger toggle
  const burger = document.querySelector<HTMLButtonElement>('.nav-burger');
  const links = document.querySelector<HTMLElement>('.nav-links');
  burger?.addEventListener('click', () => {
    const open = burger.getAttribute('aria-expanded') === 'true';
    burger.setAttribute('aria-expanded', String(!open));
    links?.classList.toggle('mobile-open', !open);
  });
</script>
