---
// Pure-CSS MacBook device frame. Drop a screenshot in the default slot:
// <LaptopMock><Image .../></LaptopMock>. Positioning (max-width, overlap)
// is left to the parent so the same frame works in a hero or inside a card.
---

<div class="laptop">
  <div class="screen">
    <div class="camera"><span></span></div>
    <div class="screen-inner">
      <slot />
    </div>
  </div>
  <div class="base-1"></div>
  <div class="base-2"><div class="notch"></div></div>
</div>

<style>
.screen {
  background: #0C0B10;
  border-radius: 20px 20px 7px 7px;
  padding: 13px 13px 15px;
  box-shadow: var(--shadow-laptop);
  border: 1px solid rgba(0, 0, 0, 0.5);
}
.camera { display: flex; align-items: center; justify-content: center; padding: 1px 0 9px; }
.camera span { width: 6px; height: 6px; border-radius: 50%; background: #26252c; box-shadow: inset 0 0 2px rgba(0, 0, 0, 0.8); }
.screen-inner { border-radius: 7px; overflow: hidden; background: #fff; border: 1px solid rgba(0, 0, 0, 0.4); }
.screen-inner :global(img) { width: 100%; height: auto; display: block; }
.base-1 {
  position: relative;
  height: 16px;
  background: linear-gradient(180deg, #e3e4e9 0%, #c2c3cb 55%, #a7a8b1 100%);
  border-radius: 0 0 4px 4px;
  box-shadow: inset 0 2px 2px rgba(255, 255, 255, 0.7);
}
.base-2 {
  position: relative;
  height: 11px;
  width: 104%;
  margin-left: -2%;
  background: linear-gradient(180deg, #b9bac2 0%, #9a9ba4 60%, #7e7f88 100%);
  border-radius: 0 0 14px 14px;
  box-shadow: 0 14px 22px -10px rgba(0, 0, 0, 0.35);
}
.base-2 .notch {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 128px;
  height: 9px;
  background: linear-gradient(180deg, #86878f, #aeb0b8);
  border-radius: 0 0 9px 9px;
}
</style>
