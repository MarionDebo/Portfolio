---
// Pure-CSS MacBook device frame. Drop a screenshot in the default slot:
// <LaptopMock><Image .../></LaptopMock>. Positioning (max-width, overlap)
// is left to the parent so the same frame works in a hero or inside a card.
---

<div class="laptop">
  <div class="lid">
    <div class="camera"><span></span></div>
    <div class="display">
      <slot />
    </div>
  </div>
  <div class="deck">
    <div class="groove"></div>
  </div>
</div>

<style>
.laptop {
  display: flex;
  flex-direction: column;
  align-items: center;
  filter: drop-shadow(0 22px 30px rgba(15, 12, 30, 0.28));
}

/* Screen lid: dark aluminium bezel around the display */
.lid {
  width: 100%;
  box-sizing: border-box;
  background: linear-gradient(180deg, #2a2933 0%, #1a1922 100%);
  border-radius: 16px 16px 5px 5px;
  padding: 12px 12px 14px;
  border: 1px solid rgba(0, 0, 0, 0.45);
  box-shadow:
    inset 0 0 0 1px rgba(255, 255, 255, 0.04),
    inset 0 1px 1px rgba(255, 255, 255, 0.08);
}
.camera {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 0 8px;
}
.camera span {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: #3a3942;
  box-shadow: inset 0 0 2px rgba(0, 0, 0, 0.9);
}
.display {
  border-radius: 4px;
  overflow: hidden;
  background: #fff;
  box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.35);
  line-height: 0;
}
.display :global(img) {
  width: 100%;
  height: auto;
  display: block;
}

/* Bottom deck: a single aluminium bar, slightly wider than the lid */
.deck {
  position: relative;
  width: calc(100% + 22px);
  height: 14px;
  background: linear-gradient(180deg, #dcdde2 0%, #c0c1c9 45%, #9b9ca5 100%);
  border-radius: 0 0 11px 11px;
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.75),
    inset 0 -1px 1px rgba(0, 0, 0, 0.15);
}
/* Concave finger groove that opens the lid */
.deck .groove {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 22%;
  height: 7px;
  background: linear-gradient(180deg, #8f9099, #b6b7bf);
  border-radius: 0 0 8px 8px;
  box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.3);
}
</style>
