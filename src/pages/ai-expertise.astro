---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroDemo from '../components/HeroDemo.astro';
import GithubGraph from '../components/GithubGraph.astro';
import genaiFormation from '../assets/genai-formation.jpg';
import certifiedBadge from '../assets/certified-ai-discipline.png';

const GITHUB_URL = 'https://github.com/MarionDebo';
const CERT_URL = '#'; // TODO(owner): add the AI Discipline certification URL

// ── Build-time GitHub contributions (calendar year) ──────────────────────
// Fetched here so the graph renders instantly and works with no JS. The
// GithubGraph island re-fetches in the browser to stay fresh / recover if this
// build-time fetch was blocked.
const YEAR = 2026;
const COLORS = ['#EAE8EE', '#C3ABF6', '#9B79F1', '#7A52EC', '#6C4DF6'];
const MONTHS = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
const pad = (n: number) => String(n).padStart(2, '0');

function buildMatrix(byDate: Record<string, { level: number }>) {
  const weeks: { days: { c: string }[] }[] = [];
  const monthLabels: string[] = [];
  let prevMonth = -1;
  const d = new Date(YEAR, 0, 1);
  d.setDate(d.getDate() - d.getDay()); // back to the Sunday on/before Jan 1
  const end = new Date(YEAR, 11, 31);
  while (d <= end) {
    const wMonth = d.getMonth();
    const wYear = d.getFullYear();
    const days: { c: string }[] = [];
    for (let i = 0; i < 7; i++) {
      if (d.getFullYear() === YEAR) {
        const key = `${YEAR}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}`;
        const rec = byDate[key];
        days.push({ c: COLORS[rec ? rec.level : 0] });
      } else {
        days.push({ c: 'transparent' });
      }
      d.setDate(d.getDate() + 1);
    }
    weeks.push({ days });
    if (wYear === YEAR && wMonth !== prevMonth) { monthLabels.push(MONTHS[wMonth]); prevMonth = wMonth; }
    else monthLabels.push('');
  }
  return { weeks, monthLabels };
}

let contributions = buildMatrix({});
try {
  const ctrl = new AbortController();
  const timer = setTimeout(() => ctrl.abort(), 5000);
  const res = await fetch(`https://github-contributions-api.jogruber.de/v4/MarionDebo?y=${YEAR}`, { signal: ctrl.signal });
  clearTimeout(timer);
  if (res.ok) {
    const data = await res.json();
    const byDate: Record<string, { level: number }> = {};
    (data.contributions ?? []).forEach((c: { date: string; level: number }) => { byDate[c.date] = c; });
    contributions = buildMatrix(byDate);
  }
} catch {
  /* keep the empty Jan→Dec grid; the client island will fill it in */
}

const toolGroups = [
  { label: 'AI & LLMs', tools: [
    { n: 'Claude', d: 'claude.ai' }, { n: 'ChatGPT', d: 'openai.com' }, { n: 'Mistral', d: 'mistral.ai' },
  ]},
  { label: 'Build & specs', tools: [
    { n: 'Cursor', d: 'cursor.com' }, { n: 'GitHub', d: 'github.com' }, { n: 'Lovable', d: 'lovable.dev' },
    { n: 'Figma Make', d: 'figma.com' }, { n: 'Claude Design', d: 'claude.ai' },
  ]},
  { label: 'Analytics & evals', tools: [
    { n: 'PostHog', d: 'posthog.com' }, { n: 'Langsmith', d: 'langchain.com' }, { n: 'Custom eval tooling', d: null },
  ]},
  { label: 'Automation & agents', tools: [
    { n: 'Dust', d: 'dust.tt' }, { n: 'n8n', d: 'n8n.io' }, { n: 'Claude API', d: 'anthropic.com' }, { n: 'MCP', d: 'modelcontextprotocol.io' },
  ]},
];

const acts = [
  { href: '#build', num: '01 · BUILD IT', text: 'A year inside an AI-native product, learning where AI earns its place.' },
  { href: '#work', num: '02 · WORK WITH IT', text: 'AI distilled into how I spec, prototype and ship every day.' },
  { href: '#prove', num: '03 · PROVE IT', text: 'Agents in production and code committed in public. The receipts.' },
];
---

<BaseLayout
  title="AI Expertise — Marion Débonnaire"
  description="A PM who practises AI daily: a year on an AI-native product, a Gen-AI certification, and a craft rewired around AI tools. Build it, work with it, prove it."
>
  <!-- ░░ Hero ░░ -->
  <section class="hero gradient-hero">
    <div class="watermark" aria-hidden="true">AI-native</div>
    <div class="hero-inner">
      <div class="hero-text">
        <p class="eyebrow">AI&nbsp;EXPERTISE</p>
        <h1>I don't talk about AI.<br>I <span class="accent">ship with it.</span></h1>
        <p class="hero-lead">For over a year I've been PM on an AI-native product, earned a Gen-AI product certification, and rewired my daily craft around AI tools. This is what working <em>in</em> AI, not around it, actually looks like.</p>
      </div>
      <HeroDemo />
    </div>
  </section>

  <!-- ░░ Three-act index ░░ -->
  <section class="acts">
    <div class="acts-inner">
      {acts.map((a, i) => (
        <a href={a.href} class:list={['act', { last: i === acts.length - 1 }]}>
          <div class="act-num">{a.num}</div>
          <div class="act-text">{a.text}</div>
        </a>
      ))}
    </div>
  </section>

  <!-- ░░ 01 · BUILD IT ░░ -->
  <section id="build" class="build">
    <div class="wrap section-pad">
      <div class="marker"><span class="bar"></span><span class="lbl">01 · BUILD IT</span></div>
      <div class="build-grid">
        <div>
          <h2>A year inside an AI-native product.</h2>
          <p class="body">I spent nearly a year as PM on <strong>Toucan AI</strong>, a conversational analytics product. The biggest lesson: building an AI product is nothing like building a regular one. The real design work happens as much in the model's behavior as in the interface.</p>
          <p class="body">It also means accepting that the product is <em>probabilistic by nature</em>, and designing for it: building trust, setting the right expectations, and making the AI's reasoning legible to non-technical business users.</p>
        </div>
        <div class="build-cards">
          <div class="bcard accent">
            <div class="bcard-label light">EXPERIENCE</div>
            <div class="bcard-title light">Conversational UX</div>
          </div>
          <div class="bcard">
            <div class="bcard-label">QUALITY</div>
            <div class="bcard-title">LLM Evaluations</div>
          </div>
          <div class="bcard">
            <div class="bcard-label">ARCHITECTURE</div>
            <div class="bcard-title">Multi-agent systems</div>
          </div>
          <div class="bcard">
            <div class="bcard-label">SOVEREIGN INFRASTRUCTURE</div>
            <div class="bcard-title">Mistral &amp; Scaleway</div>
          </div>
        </div>
      </div>
      <a href="/portfolio/self-service-dashboard" class="text-link build-link">Read the Toucan AI case study →</a>
    </div>
  </section>

  <!-- ░░ 02 · WORK WITH IT ░░ -->
  <section id="work" class="work">
    <div class="wrap section-pad">
      <div class="marker"><span class="bar"></span><span class="lbl">02 · WORK WITH IT</span></div>
      <h2 class="work-h2">AI, distilled into how I ship.</h2>
      <p class="body work-intro">I use AI to move faster and deliver better, every day. It reshapes how I work with engineers and how quality gets shipped.</p>
      <div class="work-grid">
        <div class="wk-card">
          <div class="wk-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#6C4DF6" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
          </div>
          <h3>Living specs</h3>
          <p>Product requirements that live inside the codebase and can be queried. Specs that stay true to what actually shipped.</p>
        </div>
        <div class="wk-card">
          <div class="wk-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#6C4DF6" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3 1.9 5.8L20 10l-6.1 1.2L12 17l-1.9-5.8L4 10l6.1-1.2z"></path></svg>
          </div>
          <h3>Vibe coding</h3>
          <p>UI/UX iterations straight in Cursor and GitHub, shipping small improvements myself instead of queueing dev time.</p>
        </div>
        <div class="wk-card">
          <div class="wk-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#6C4DF6" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="12" rx="2"></rect><path d="M9 20h6M12 16v4M9 9h.01M15 9h.01M9.5 12.5a3 3 0 0 0 5 0"></path></svg>
          </div>
          <h3>Agents in production</h3>
          <p>Live agents doing real work: user-feedback analysis, competitive monitoring, and product documentation. n8n in 2025, Claude agents in 2026.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ░░ 03 · PROVE IT ░░ -->
  <section id="prove" class="prove">
    <div class="wrap section-pad">
      <div class="marker"><span class="bar"></span><span class="lbl">03 · PROVE IT</span></div>
      <div class="prove-head">
        <h2>I ship with AI. Here's the receipt.</h2>
        <p class="body">My GitHub contributions are the simplest proof that I've folded AI into my daily work, whether I'm writing specs or vibe coding.</p>
      </div>
      <GithubGraph weeks={contributions.weeks} monthLabels={contributions.monthLabels} year={YEAR} githubUrl={GITHUB_URL} />
    </div>
  </section>

  <!-- ░░ Point of view ░░ -->
  <section class="pov">
    <div class="pov-inner">
      <div class="pov-eyebrow">POINT OF VIEW</div>
      <blockquote>Most AI features fail not because the model is wrong, but because the product never makes it obvious <span class="pov-accent">when to trust it and when not to.</span> Building that trust layer is the real PM job in AI.</blockquote>
    </div>
  </section>

  <!-- ░░ Formation ░░ -->
  <section class="formation">
    <div class="wrap section-pad">
      <div class="marker formation-marker"><span class="bar"></span><span class="lbl">GROUNDED IN THEORY</span></div>
      <div class="formation-grid">
        <Image src={genaiFormation} alt="GenAI · Les Fondamentaux, AI Discipline — Tristan Charvillat" class="formation-img" widths={[600, 900, 1200]} sizes="(max-width: 860px) 90vw, 600px" />
        <div>
          <div class="cert-row">
            <Image src={certifiedBadge} alt="Certified by AI Discipline" width={74} height={74} class="cert-badge" />
            <span class="cert-pill">CERTIFIED · 2025</span>
          </div>
          <h2 class="formation-h2">GenAI · Les Fondamentaux</h2>
          <p class="body formation-desc">The GenAI foundations program by <strong>AI Discipline</strong>, led by Rémi Guyot (ex-Booking.com CPO) and Tristan Charvillat (VP Design, Malt). Theory to back up a year of hands-on practice.</p>
          <div class="formation-bullets">
            <div><span class="b-dot"></span>Prompting methodology</div>
            <div><span class="b-dot"></span>RAG &amp; knowledge-base structuring</div>
            <div><span class="b-dot"></span>Building &amp; configuring AI assistants</div>
          </div>
          <a href={CERT_URL} class="text-link">View the certification →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ░░ Tools & Stack ░░ -->
  <section class="tools">
    <div class="wrap section-pad">
      <div class="marker"><span class="bar"></span><span class="lbl">TOOLS &amp; STACK</span></div>
      <h2 class="tools-h2">The kit I build with.</h2>
      <p class="body tools-intro">A modern, connected stack, wired together so the tools talk to each other instead of sitting in silos.</p>
      <div class="tools-grid">
        {toolGroups.map(group => (
          <div class="tool-group">
            <div class="tool-group-label">{group.label}</div>
            <div class="tool-row">
              {group.tools.map(t => (
                <div class="tool">
                  <span class="tip">{t.n}</span>
                  <span class="tile">
                    {t.d
                      ? <img src={`https://www.google.com/s2/favicons?domain=${t.d}&sz=64`} alt={`${t.n} logo`} width="30" height="30" loading="lazy" decoding="async" />
                      : <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#6C4DF6" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"></path></svg>}
                  </span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.wrap { max-width: var(--max-content); margin: 0 auto; padding-inline: var(--gutter); }
.section-pad { padding-block: 90px 96px; }
.body { font-size: 18px; line-height: 1.64; color: var(--color-muted-2); margin: 0 0 18px; }
.body:last-of-type { margin-bottom: 0; }
.body strong { color: var(--color-ink); }
.body em { font-style: normal; color: var(--color-ink); }

.text-link {
  font-family: var(--font-mono);
  font-size: 13px;
  color: var(--color-ink);
  display: inline-flex;
  align-items: center;
  gap: 8px;
  border-bottom: 2px solid var(--color-accent);
  padding-bottom: 3px;
}

.marker { display: flex; align-items: center; gap: 14px; margin-bottom: 22px; }
.marker .bar { width: 30px; height: 3px; background: var(--color-accent); border-radius: 2px; }
.marker .lbl { font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.16em; color: var(--color-accent); }

/* ── Hero ── */
.hero {
  margin-top: calc(-1 * var(--nav-bleed));
  padding: 150px var(--gutter) 80px;
  position: relative;
  overflow: hidden;
}
.watermark {
  position: absolute;
  top: 96px;
  left: 50%;
  transform: translateX(-50%);
  font-family: var(--font-display);
  font-weight: 600;
  font-size: clamp(160px, 26vw, 320px);
  line-height: 1;
  color: var(--color-accent);
  opacity: 0.05;
  letter-spacing: -0.04em;
  pointer-events: none;
  user-select: none;
  white-space: nowrap;
}
.hero-inner {
  max-width: var(--max-content);
  margin: 0 auto;
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 1.35fr 1fr;
  gap: 56px;
  align-items: center;
}
.eyebrow { font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.18em; color: var(--color-accent); margin: 0 0 26px; }
.hero-text h1 {
  font-size: clamp(44px, 5.2vw, 70px);
  font-weight: 600;
  line-height: 1.05;
  letter-spacing: -0.035em;
  margin: 0 0 28px;
  color: var(--color-ink);
  white-space: nowrap; /* keep "I don't talk about AI." on one line */
}
.hero-text h1 .accent { color: var(--color-accent); }
.hero-lead { font-size: 20px; line-height: 1.62; color: var(--color-muted-2); max-width: 48ch; margin: 0; }
.hero-lead em { font-style: normal; color: var(--color-ink); border-bottom: 2px solid var(--color-accent); }

/* ── Three-act index ── */
.acts { background: var(--color-bg-white); border-top: 1px solid rgba(0, 0, 0, 0.06); }
.acts-inner { max-width: var(--max-content); margin: 0 auto; padding: 18px var(--gutter); display: grid; grid-template-columns: repeat(3, 1fr); }
.act { display: block; padding: 26px 28px; border-right: 1px solid rgba(0, 0, 0, 0.08); }
.act:first-child { padding-left: 0; }
.act.last { border-right: none; padding-right: 0; padding-left: 28px; }
.act-num { font-family: var(--font-mono); font-size: 12px; color: var(--color-accent); margin-bottom: 10px; }
.act-text { font-family: var(--font-display); font-weight: 600; font-size: 18px; color: var(--color-ink); letter-spacing: -0.01em; }

/* ── 01 · BUILD IT ── */
.build { background: var(--color-bg-cream); scroll-margin-top: 90px; }
.build h2 {
  font-size: clamp(30px, 3.4vw, 44px);
  font-weight: 600;
  line-height: 1.08;
  letter-spacing: -0.03em;
  color: var(--color-ink);
  margin: 0 0 22px;
}
.build-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: end; }
.build-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.bcard { background: #fff; border: 1px solid rgba(0, 0, 0, 0.08); border-radius: 14px; padding: 20px; }
.bcard.accent { background: var(--color-accent); border-color: var(--color-accent); }
.bcard-label { font-family: var(--font-mono); font-size: 11px; color: var(--color-meta); margin-bottom: 10px; }
.bcard-label.light { color: var(--violet-200); }
.bcard-title { font-family: var(--font-display); font-weight: 600; font-size: 17px; color: var(--color-ink); line-height: 1.25; }
.bcard-title.light { color: #fff; }
.build-link { margin-top: 44px; }

/* ── 02 · WORK WITH IT ── */
.work { background: var(--color-bg-white); scroll-margin-top: 90px; }
.work-h2 {
  font-size: clamp(30px, 3.4vw, 44px);
  font-weight: 600;
  line-height: 1.08;
  letter-spacing: -0.03em;
  color: var(--color-ink);
  margin: 0 0 14px;
  max-width: 20ch;
}
.work-intro { max-width: 60ch; margin-bottom: 50px; }
.work-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
.wk-card {
  border: 1px solid rgba(0, 0, 0, 0.09);
  border-radius: 18px;
  padding: 30px;
  background: #FBFAF8;
  transition: transform 240ms ease, box-shadow 240ms ease, border-color 240ms ease;
}
.wk-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-soft); border-color: rgba(var(--color-accent-rgb), 0.3); }
.wk-icon { width: 44px; height: 44px; border-radius: 12px; background: var(--color-bg-lilac); display: flex; align-items: center; justify-content: center; margin-bottom: 22px; }
.wk-card h3 { font-size: 21px; font-weight: 600; letter-spacing: -0.02em; color: var(--color-ink); margin: 0 0 10px; }
.wk-card p { font-size: 15.5px; line-height: 1.58; color: var(--color-muted-2); margin: 0; }

/* ── 03 · PROVE IT ── */
.prove { background: var(--color-bg-cream); scroll-margin-top: 90px; }
.prove-head { display: flex; justify-content: space-between; align-items: flex-end; flex-wrap: wrap; gap: 20px; margin-bottom: 34px; }
.prove h2 {
  font-size: clamp(30px, 3.4vw, 44px);
  font-weight: 600;
  line-height: 1.08;
  letter-spacing: -0.03em;
  color: var(--color-ink);
  margin: 0 0 12px;
}
.prove-head .body { max-width: 52ch; }

/* ── Point of view ── */
.pov { background: var(--color-dark); color: var(--color-dark-text); }
.pov-inner { max-width: 1000px; margin: 0 auto; padding: 96px var(--gutter); text-align: center; }
.pov-eyebrow { font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.16em; color: var(--color-dark-meta); margin-bottom: 30px; }
.pov blockquote {
  font-family: var(--font-display);
  font-weight: 500;
  font-size: clamp(26px, 3.2vw, 40px);
  line-height: 1.28;
  letter-spacing: -0.02em;
  color: #fff;
  margin: 0;
}
.pov-accent { color: var(--violet-400); }

/* ── Formation ── */
.formation { background: var(--color-bg-white); }
.formation-marker { margin-bottom: 34px; }
.formation-grid { display: grid; grid-template-columns: 1.08fr 0.92fr; gap: 56px; align-items: center; }
.formation-img { display: block; width: 100%; height: auto; border-radius: 18px; border: 1px solid rgba(0, 0, 0, 0.08); box-shadow: var(--shadow-soft); }
.cert-row { display: flex; align-items: center; gap: 16px; margin-bottom: 24px; }
.cert-badge { display: block; flex-shrink: 0; }
.cert-pill { font-family: var(--font-mono); font-size: 11px; color: var(--color-accent); background: var(--color-bg-lilac-tint); padding: 6px 13px; border-radius: var(--radius-pill); }
.formation-h2 { font-size: clamp(28px, 3vw, 38px); font-weight: 600; line-height: 1.1; letter-spacing: -0.025em; color: var(--color-ink); margin: 0 0 14px; }
.formation-desc { font-size: 17px; line-height: 1.6; margin-bottom: 24px; }
.formation-bullets { display: flex; flex-direction: column; gap: 11px; margin-bottom: 28px; }
.formation-bullets > div { display: flex; align-items: center; gap: 11px; font-size: 15.5px; color: var(--color-body); }
.b-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent); flex-shrink: 0; }

/* ── Tools & Stack ── */
.tools { background: var(--color-bg-lilac); }
.tools-h2 { font-size: clamp(28px, 3vw, 40px); font-weight: 600; line-height: 1.1; letter-spacing: -0.025em; color: var(--color-ink); margin: 0 0 12px; }
.tools-intro { max-width: 54ch; font-size: 17px; line-height: 1.6; }
.tools-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 48px 56px; margin-top: 48px; }
.tool-group-label { font-family: var(--font-mono); font-size: 11px; color: #7a7488; letter-spacing: 0.08em; margin-bottom: 22px; }
.tool-row { display: flex; gap: 16px; flex-wrap: wrap; }
.tile {
  width: 56px;
  height: 56px;
  border-radius: 15px;
  background: #fff;
  border: 1px solid rgba(0, 0, 0, 0.08);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 8px -3px rgba(40, 25, 90, 0.14);
}
.tile img { display: block; border-radius: 7px; }

@media (max-width: 860px) {
  .hero { padding: 120px var(--gutter) 64px; }
  .hero-inner { grid-template-columns: 1fr; gap: 44px; }
  .hero-text h1 { white-space: normal; } /* allow wrapping on narrow screens */
  .acts-inner { grid-template-columns: 1fr; }
  .act, .act:first-child, .act.last { padding: 22px 0; border-right: none; border-bottom: 1px solid rgba(0, 0, 0, 0.08); }
  .act.last { border-bottom: none; }
  .build-grid { grid-template-columns: 1fr; gap: 40px; align-items: start; }
  .work-grid { grid-template-columns: 1fr; }
  .formation-grid { grid-template-columns: 1fr; gap: 36px; }
  .tools-grid { grid-template-columns: 1fr; gap: 40px; }
  .section-pad { padding-block: 64px; }
}
</style>
