---
import BaseLayout from '../layouts/BaseLayout.astro';

const domains = [
  {
    icon: '🧠',
    title: 'AI-Native Product Design',
    description: 'Building an AI product is not like building a regular product. I spent nearly a year as PM on Toucan AI, where I learned that the real design work happens as much in the model behavior as in the interface.',
    details: 'In practice, this means: shaping how the AI responds through system prompt design, understanding how agents interact within a multi-agent architecture, and working closely with the constraints and specificities of the model we use. It also means accepting that the product is probabilistic by nature, and designing the user experience accordingly: building trust, setting the right expectations, and making AI reasoning legible to non-technical business users.',
    bullets: [
      'System prompt design and iteration',
      'Multi-agent architecture: understanding agent interactions and dependencies',
      'Sovereign AI stack: Mistral + Scaleway',
      'Designing conversational experiences for business decision-making',
    ],
  },
  {
    icon: '⚙️',
    title: 'AI in the PM Workflow',
    description: 'I use AI to move faster and deliver better, every day. From vibe coding UI changes in Cursor to writing living specs embedded in the codebase, AI has changed how I interact with engineers and ship quality.',
    details: null,
    bullets: [
      'UI/UX iterations with Cursor and GitHub, reducing dev dependency on small improvements',
      'Living specs: product requirements that live inside the codebase and can be queried',
      'AI agents: user feedback analysis (n8n in 2025, Claude agent in 2026), competitive monitoring agent',
    ],
  },
  {
    icon: '🎓',
    title: 'Certified: Gen AI for Product Teams',
    description: 'Completed the "Gen AI for Product Teams" certification by AI Discipline, led by Rémi Guyot (ex-Booking.com CPO) and Tristan Charvillat (VP Design Malt), 2025.',
    details: null,
    bullets: [
      'Prompting methodology',
      'RAG and knowledge base structuring',
      'Building and configuring AI assistants',
    ],
    certifLink: true,
  },
];

const tools = [
  { category: 'AI & LLMs', items: ['Claude', 'ChatGPT', 'Dust'] },
  { category: 'Vibe coding & specs', items: ['Cursor', 'GitHub', 'Figma Make', 'Lovable'] },
  { category: 'Automation & agents', items: ['n8n', 'Claude API'] },
];
---

<BaseLayout
  title="AI Expertise — Marion Débonnaire"
  description="How I approach AI-native product design, ship with AI tools daily, and build products at the intersection of trust and intelligence."
>
  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb text-muted">
        <a href="/">Home</a>
        <span aria-hidden="true">›</span>
        <span>AI Expertise</span>
      </div>
      <h1 class="page-title">
        I don't talk about AI.<br />
        <em class="title-em">I ship with it.</em>
      </h1>
      <p class="page-sub text-muted">
        AI has changed what it means to be a product manager. I've spent the last year building that new muscle: shipping an AI-native product, getting certified, and rewiring my daily workflow around AI tools. Here is what that looks like in practice.
      </p>
    </div>
  </section>

  <!-- Domains -->
  <section class="domains">
    <div class="container">
      <h2 class="section-title">Domains of expertise</h2>

      <div class="domains-list">
        {domains.map(d => (
          <article class="domain-block">
            <div class="domain-header">
              <span class="domain-icon" aria-hidden="true">{d.icon}</span>
              <h3>{d.title}</h3>
            </div>
            <p class="text-muted">{d.description}</p>
            {d.details && <p class="text-muted">{d.details}</p>}
            <ul class="domain-bullets" role="list">
              {d.bullets.map(b => (
                <li>
                  <span class="bullet-dot" aria-hidden="true"></span>
                  {b}
                </li>
              ))}
            </ul>
            {d.certifLink && (
              <p class="certif-link text-muted">Certification link coming soon →</p>
            )}
          </article>
        ))}
      </div>
    </div>
  </section>


  <!-- Tools -->
  <section class="tools-section">
    <div class="container">
      <h2 class="section-title">Tools & stack</h2>

      <div class="tools-list">
        {tools.map(group => (
          <div class="tool-row">
            <h3 class="tool-category">{group.category}</h3>
            <div class="tool-pills">
              {group.items.map(item => (
                <span class="tag">{item}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Building in public -->
  <section class="github-section">
    <div class="container">
      <div class="github-inner card">
        <div class="github-header">
          <div class="github-text">
            <span class="github-label text-muted">I don't just spec, I ship.</span>
            <h2 class="github-title">Building in public</h2>
            <p class="text-muted github-desc">From data pipelines to product prototypes, I use code as a thinking tool. This portfolio is built and maintained by me.</p>
          </div>
          <div class="github-meta">
            <a href="https://github.com/MarionDebo" target="_blank" rel="noopener noreferrer" class="btn btn-outline github-btn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
              View on GitHub
            </a>
          </div>
        </div>
        <div class="github-graph">
          <div class="calendar"></div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.page-hero {
  padding-top: calc(var(--space-20) + var(--space-8));
  padding-bottom: var(--space-16);
}

.breadcrumb {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--text-sm);
  margin-bottom: var(--space-6);
}
.breadcrumb a:hover { color: var(--color-text); }

.page-title {
  font-family: var(--font-display);
  font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
  font-weight: 800;
  letter-spacing: -0.03em;
  line-height: var(--leading-tight);
  margin-bottom: var(--space-6);
}

.title-em {
  font-style: italic;
  font-weight: 300;
  color: var(--color-accent);
}

.page-sub {
  font-size: var(--text-lg);
  max-width: 620px;
  line-height: var(--leading-normal);
}

/* Domains */
.domains { background: rgba(255,255,255,0.28); padding-bottom: var(--space-16); }

.section-title {
  font-family: var(--font-display);
  font-size: var(--text-3xl);
  font-weight: 800;
  letter-spacing: -0.025em;
  margin-bottom: var(--space-3);
}

.domains-list {
  margin-top: var(--space-10);
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-8);
  align-items: start;
}

.domain-block {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  padding: var(--space-6);
  border-left: 2px solid var(--color-accent);
  background: rgba(255,255,255,0.4);
  border-radius: 0 var(--radius-md) var(--radius-md) 0;
}

.domain-header {
  display: flex;
  align-items: center;
  gap: var(--space-3);
}

.domain-icon { font-size: 1.5rem; }

.domain-block h3 {
  font-family: var(--font-display);
  font-size: var(--text-lg);
  font-weight: 700;
  letter-spacing: -0.015em;
}

.domain-details {
  font-size: var(--text-sm);
  line-height: var(--leading-normal);
}

.domain-bullets {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  margin-top: auto;
  padding-top: var(--space-4);
  border-top: 1px solid var(--color-border-soft);
}

.domain-bullets li {
  display: flex;
  align-items: baseline;
  gap: var(--space-2);
  font-size: var(--text-sm);
  color: var(--color-text-muted);
}

.bullet-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--color-accent);
  flex-shrink: 0;
  margin-top: 6px;
}

.certif-link {
  font-size: var(--text-sm);
  font-style: italic;
  margin-top: var(--space-2);
}

/* Insight */
.insight-section { background: transparent; }

.insight-box {
  overflow: hidden;
  padding: var(--space-12);
}

.insight-content { position: relative; z-index: 1; }

.insight-label {
  font-size: var(--text-xs);
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  display: block;
  margin-bottom: var(--space-4);
}

blockquote {
  font-size: clamp(var(--text-lg), 2.5vw, var(--text-2xl));
  font-weight: 400;
  line-height: var(--leading-snug);
  color: var(--color-text);
  max-width: 780px;
  font-style: italic;
}

/* Tools */
.tools-section { background: rgba(255,255,255,0.28); }

.section-sub {
  margin-top: var(--space-3);
  margin-bottom: var(--space-10);
  font-size: var(--text-lg);
}

.tools-list {
  margin-top: var(--space-10);
  display: flex;
  flex-direction: column;
}

.tool-row {
  display: grid;
  grid-template-columns: 200px 1fr;
  align-items: center;
  gap: var(--space-8);
  padding: var(--space-8) 0;
  border-top: 1px solid var(--color-border-soft);
}

.tool-row:last-child {
  border-bottom: 1px solid var(--color-border-soft);
}

.tool-category {
  font-size: var(--text-xs);
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--color-text-muted);
}

.tool-pills {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
}

/* CTA */
.cta-section { background: transparent; }

.cta-box {
  overflow: hidden;
  padding: var(--space-12);
}

.cta-inner { position: relative; z-index: 1; }

.cta-box h2 {
  font-family: var(--font-display);
  font-size: var(--text-2xl);
  font-weight: 800;
  letter-spacing: -0.025em;
  margin-bottom: var(--space-3);
}

.cta-box p { max-width: 480px; margin-bottom: var(--space-6); }

.cta-actions { display: flex; gap: var(--space-3); flex-wrap: wrap; }

/* GitHub */
.github-section { background: rgba(255,255,255,0.28); }

.github-inner {
  display: flex;
  flex-direction: column;
  gap: var(--space-8);
}

.github-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-8);
}

.github-meta {
  display: flex;
  align-items: center;
  gap: var(--space-6);
  flex-shrink: 0;
}

.github-graph {
  width: 100%;
  overflow: hidden;
  padding: var(--space-4);
  background: rgba(255,255,255,0.5);
  border-radius: var(--radius-md);
}

.github-label {
  display: block;
  font-size: var(--text-xs);
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  margin-bottom: var(--space-2);
}

.github-title {
  font-family: var(--font-display);
  font-size: var(--text-2xl);
  font-weight: 800;
  letter-spacing: -0.025em;
  margin-bottom: var(--space-3);
}

.github-desc {
  font-size: var(--text-sm);
  max-width: 480px;
}

.github-btn {
  display: inline-flex;
  gap: var(--space-2);
  align-items: center;
}

.github-btn:hover {
  background: #f0f0f0 !important;
  color: var(--color-text) !important;
  border-color: #d0d0d0 !important;
}

.calendar {
  width: 100%;
  overflow: hidden;
}

.calendar h2,
.calendar .skip-to-content,
.calendar a[href*="skip"] {
  display: none !important;
}

.calendar svg {
  width: 100% !important;
  height: auto !important;
  display: block;
}

.calendar > div,
.calendar .js-calendar-graph,
.calendar .ContributionCalendar {
  border: none !important;
  box-shadow: none !important;
}

.calendar text { font-family: var(--font-sans) !important; font-size: 10px !important; fill: var(--color-text-muted) !important; }

.calendar .contrib-legend,
.calendar .contrib-legend text,
.calendar .contrib-legend span {
  font-size: 9px !important;
  color: var(--color-text-faint) !important;
  fill: var(--color-text-faint) !important;
}

/* Responsive */
@media (max-width: 1024px) {
  .domains-list { grid-template-columns: 1fr; }
}

@media (max-width: 768px) {
  .domains-list { grid-template-columns: 1fr; }
  .tool-row { grid-template-columns: 1fr; gap: var(--space-3); }
  .github-header {
    flex-direction: column;
    gap: var(--space-4);
  }
  .github-meta {
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-3);
  }
}
</style>

<link rel="stylesheet" href="https://unpkg.com/github-calendar@latest/dist/github-calendar-responsive.css" />

<script is:inline>
  (function loadCalendar() {
    const cal = document.querySelector('.calendar');

    const observer = new MutationObserver(function() {
      cal.querySelectorAll('h2, [aria-hidden="true"] + h2, a').forEach(function(el) {
        const text = el.textContent.trim();
        if (text.includes('Skip') || text.includes('Contribution Graph')) {
          el.remove();
        }
      });
      cal.querySelectorAll('*').forEach(function(el) {
        const text = el.textContent.trim();
        if ((text === 'Less' || text === 'More') && el.children.length === 0) {
          el.style.fontSize = '9px';
          el.style.color = '#A0A8B0';
        }
        el.style.border = 'none';
        el.style.boxShadow = 'none';
        el.style.outline = 'none';
        if (el.tagName === 'DIV' && el.querySelector('svg')) {
          el.style.paddingLeft = '12px';
        }
      });
    });
    observer.observe(cal, { childList: true, subtree: true });

    const script = document.createElement('script');
    script.src = 'https://unpkg.com/github-calendar@latest/dist/github-calendar.min.js';
    script.onload = function () {
      GitHubCalendar('.calendar', 'MarionDebo', {
        responsive: true,
        tooltips: true,
        global_stats: false,
        year: 2026,
      });
    };
    document.head.appendChild(script);
  })();
</script>
