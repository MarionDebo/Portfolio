---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Tag from '../components/Tag.astro';

const domains = [
  {
    icon: '🧠',
    title: 'AI-Native Product Design',
    description: 'Building an AI product is not like building a regular product. I spent nearly a year as PM on Toucan AI, where I learned that the real design work happens as much in the model behavior as in the interface.',
    details: 'In practice, this means: shaping how the AI responds through system prompt design, understanding how agents interact within a multi-agent architecture, and working closely with the constraints and specificities of the model we use. It also means accepting that the product is probabilistic by nature, and designing the user experience accordingly: building trust, setting the right expectations, and making AI reasoning legible to non-technical business users.',
    bullets: [
      'System prompt design and iteration',
      'Multi-agent architecture: understanding agent interactions and dependencies',
      'Sovereign AI stack: Mistral + Scaleway',
      'Designing conversational experiences for business decision-making',
    ],
  },
  {
    icon: '⚙️',
    title: 'AI in the PM Workflow',
    description: 'I use AI to move faster and deliver better, every day. From vibe coding UI changes in Cursor to writing living specs embedded in the codebase, AI has changed how I interact with engineers and ship quality.',
    details: null,
    bullets: [
      'UI/UX iterations with Cursor and GitHub, reducing dev dependency on small improvements',
      'Living specs: product requirements that live inside the codebase and can be queried',
      'AI agents: user feedback analysis (n8n in 2025, Claude agent in 2026), competitive monitoring agent',
    ],
  },
  {
    icon: '🎓',
    title: 'Certified: Gen AI for Product Teams',
    description: 'Completed the "Gen AI for Product Teams" certification by AI Discipline, led by Rémi Guyot (ex-Booking.com CPO) and Tristan Charvillat (VP Design Malt), 2025.',
    details: null,
    bullets: [
      'Prompting methodology',
      'RAG and knowledge base structuring',
      'Building and configuring AI assistants',
    ],
    certifLink: true,
  },
];

const tools = [
  { category: 'AI & LLMs', items: ['Claude', 'ChatGPT', 'Dust'] },
  { category: 'Vibe coding & specs', items: ['Cursor', 'GitHub', 'Figma Make', 'Lovable'] },
  { category: 'Automation & agents', items: ['n8n', 'Claude API'] },
];
---

<BaseLayout
  title="AI Expertise — Marion Débonnaire"
  description="How I approach AI-native product design, ship with AI tools daily, and build products at the intersection of trust and intelligence."
>
  <!-- ░░ Header ░░ -->
  <section class="ai-header gradient-hero nav-bleed">
    <div class="header-inner">
      <p class="eyebrow">AI&nbsp;EXPERTISE</p>
      <h1>I don't talk about AI.<br><span class="accent">I ship with it.</span></h1>
      <p class="lead">AI has changed what it means to be a product manager. I've spent the last year building that new muscle: shipping an AI-native product, getting certified, and rewiring my daily workflow around AI tools. Here is what that looks like in practice.</p>
    </div>
  </section>

  <!-- ░░ Domains of expertise ░░ -->
  <section class="domains">
    <div class="wrap">
      <div class="domains-header"><SectionHeader title="Domains of expertise" /></div>
      <div class="domains-list">
        {domains.map((d, i) => (
          <article class="domain">
            <div class="domain-top">
              <span class="domain-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="domain-icon" aria-hidden="true">{d.icon}</span>
              <h3>{d.title}</h3>
            </div>
            <div class="domain-body">
              <p>{d.description}</p>
              {d.details && <p>{d.details}</p>}
              <ul class="bullets" role="list">
                {d.bullets.map(b => (
                  <li><span class="dot" aria-hidden="true"></span>{b}</li>
                ))}
              </ul>
              {d.certifLink && <p class="certif">Certification link coming soon →</p>}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ░░ Building in public ░░ -->
  <section class="gh-section">
    <div class="wrap">
      <div class="gh-card">
        <div class="gh-header">
          <div class="gh-text">
            <p class="eyebrow accent-eyebrow">I DON'T JUST SPEC, I SHIP.</p>
            <h2>Building in public</h2>
            <p class="gh-desc">From data pipelines to product prototypes, I use code as a thinking tool. This portfolio is built and maintained by me.</p>
          </div>
          <a href="https://github.com/MarionDebo" target="_blank" rel="noopener noreferrer" class="gh-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
            View on GitHub
          </a>
        </div>
        <div class="gh-graph"><div class="calendar"></div></div>
      </div>
    </div>
  </section>

  <!-- ░░ Tools & stack ░░ -->
  <section class="tools-section">
    <div class="wrap">
      <div class="tools-header"><SectionHeader title="Tools & stack" /></div>
      <div class="tools-list">
        {tools.map(group => (
          <div class="tool-row">
            <div class="tool-category">{group.category}</div>
            <div class="tool-pills">
              {group.items.map(item => <Tag>{item}</Tag>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<link rel="stylesheet" href="https://unpkg.com/github-calendar@latest/dist/github-calendar-responsive.css" />

<style>
/* Header */
.header-inner {
  max-width: var(--max-nav);
  margin: 0 auto;
  padding: 72px var(--gutter) 64px;
}
.eyebrow {
  font-family: var(--font-mono);
  font-size: 12px;
  letter-spacing: 0.18em;
  color: var(--color-accent);
  margin: 0 0 26px;
}
.ai-header h1 {
  font-size: 62px;
  font-weight: 600;
  line-height: 1.04;
  letter-spacing: -0.03em;
  margin: 0 0 24px;
  color: var(--color-ink);
}
.ai-header h1 .accent { color: var(--color-accent); }
.lead {
  font-size: 20px;
  line-height: 1.6;
  color: var(--color-muted);
  max-width: 58ch;
  margin: 0;
}

/* Domains */
.domains { background: var(--color-bg-white); }
.domains .wrap { padding-block: 72px; }
.domains-header { margin-bottom: 44px; }
.domains-list { display: flex; flex-direction: column; gap: 20px; }
.domain {
  background: var(--color-bg-lilac-soft);
  border: var(--border-accent-12);
  border-radius: var(--radius-card);
  padding: 36px 40px;
}
.domain-top { display: flex; align-items: center; gap: 14px; margin-bottom: 18px; }
.domain-num {
  font-family: var(--font-mono);
  font-size: 13px;
  color: var(--color-accent);
}
.domain-icon { font-size: 1.5rem; line-height: 1; }
.domain-top h3 {
  font-size: 23px;
  font-weight: 600;
  letter-spacing: -0.015em;
  color: var(--color-ink);
  margin: 0;
}
.domain-body { display: flex; flex-direction: column; gap: 16px; }
.domain-body p { font-size: 17px; line-height: 1.65; color: var(--color-muted); margin: 0; }
.bullets {
  list-style: none;
  margin: 4px 0 0;
  padding: 18px 0 0;
  border-top: 1px solid rgba(var(--color-accent-rgb), 0.14);
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.bullets li {
  display: flex;
  align-items: baseline;
  gap: 12px;
  font-size: 16px;
  line-height: 1.55;
  color: var(--color-body-soft);
}
.dot { width: 5px; height: 5px; border-radius: 50%; background: var(--color-accent); flex-shrink: 0; transform: translateY(-2px); }
.certif { font-family: var(--font-mono); font-size: 13px; color: var(--color-meta) !important; }

/* Building in public */
.gh-section { background: var(--color-bg-lilac); }
.gh-section .wrap { padding-block: 72px; }
.gh-card {
  background: var(--color-bg-white);
  border: var(--border-accent-12);
  border-radius: var(--radius-card);
  padding: 40px;
  display: flex;
  flex-direction: column;
  gap: 32px;
}
.gh-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 32px; }
.accent-eyebrow { margin: 0 0 12px; letter-spacing: 0.14em; }
.gh-text h2 { font-size: 28px; font-weight: 600; letter-spacing: -0.02em; color: var(--color-ink); margin: 0 0 10px; }
.gh-desc { font-size: 16px; line-height: 1.6; color: var(--color-muted); max-width: 52ch; margin: 0; }
.gh-btn {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-mono);
  font-size: 13px;
  color: var(--color-ink);
  padding: 12px 20px;
  border: 1px solid rgba(var(--color-accent-rgb), 0.35);
  border-radius: var(--radius-pill);
  transition: background 200ms ease, color 200ms ease, border-color 200ms ease;
}
.gh-btn:hover { background: var(--color-accent); border-color: var(--color-accent); color: #fff; }
.gh-graph { width: 100%; overflow: hidden; padding: 18px; background: var(--color-bg-lilac-soft); border-radius: var(--radius-card); }
.calendar { width: 100%; overflow: hidden; }
.calendar :global(h2),
.calendar :global(.skip-to-content) { display: none !important; }
.calendar :global(svg) { width: 100% !important; height: auto !important; display: block; }
.calendar :global(text) { font-family: var(--font-mono) !important; font-size: 10px !important; fill: var(--color-meta) !important; }

/* Tools */
.tools-section { background: var(--color-bg-white); }
.tools-section .wrap { padding-block: 72px; }
.tools-header { margin-bottom: 32px; }
.tools-list { display: flex; flex-direction: column; }
.tool-row {
  display: grid;
  grid-template-columns: 220px 1fr;
  align-items: center;
  gap: 32px;
  padding: 28px 0;
  border-top: 1px solid rgba(0, 0, 0, 0.08);
}
.tool-row:last-child { border-bottom: 1px solid rgba(0, 0, 0, 0.08); }
.tool-category {
  font-family: var(--font-mono);
  font-size: 12px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--color-meta);
}
.tool-pills { display: flex; flex-wrap: wrap; gap: 8px; }

@media (max-width: 760px) {
  .ai-header h1 { font-size: clamp(40px, 11vw, 62px); }
  .header-inner { padding: 56px var(--gutter) 48px; }
  .domain { padding: 28px 24px; }
  .gh-header { flex-direction: column; gap: 20px; }
  .gh-card { padding: 28px 24px; }
  .tool-row { grid-template-columns: 1fr; gap: 12px; }
}
</style>

<script is:inline>
  (function loadCalendar() {
    const cal = document.querySelector('.calendar');
    if (!cal) return;

    const observer = new MutationObserver(function () {
      cal.querySelectorAll('h2, a').forEach(function (el) {
        const text = el.textContent.trim();
        if (text.includes('Skip') || text.includes('Contribution Graph')) el.remove();
      });
      cal.querySelectorAll('*').forEach(function (el) {
        const text = el.textContent.trim();
        if ((text === 'Less' || text === 'More') && el.children.length === 0) {
          el.style.fontSize = '9px';
          el.style.color = '#8a8594';
        }
        el.style.border = 'none';
        el.style.boxShadow = 'none';
        el.style.outline = 'none';
      });
    });
    observer.observe(cal, { childList: true, subtree: true });

    const script = document.createElement('script');
    script.src = 'https://unpkg.com/github-calendar@latest/dist/github-calendar.min.js';
    script.onload = function () {
      GitHubCalendar('.calendar', 'MarionDebo', {
        responsive: true,
        tooltips: true,
        global_stats: false,
        year: 2026,
      });
    };
    document.head.appendChild(script);
  })();
</script>
