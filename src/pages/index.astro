---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import portrait from '../assets/portrait-Marion.jpg';
---

<BaseLayout
  title="Marion Dupont — PM · AI-native Analytics"
  description="Product Manager specialised in AI-native embedded analytics SaaS. I turn data complexity into product clarity."
>

  <!-- ── Hero ─────────────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-content">
        <div class="hero-badge">
          <span class="badge-dot"></span>
          <span>Available · Paris / Remote</span>
        </div>

        <h1 class="hero-title">
          Making data<br />
          <em class="hero-em">actually</em><br />
          useful.
        </h1>

        <p class="hero-subtitle">
          I'm Marion, a Product Manager at the intersection of AI, analytics, and B2B SaaS.
          I build embedded analytics products that surface the right insight at the right moment —
          no dashboard archaeology required.
        </p>

        <div class="hero-actions">
          <a href="/portfolio" class="btn btn-primary">See my work</a>
          <a href="/my-story" class="btn btn-outline">My story</a>
        </div>

        <div class="hero-stats">
          <div class="stat">
            <span class="stat-value">7+</span>
            <span class="stat-label text-muted">Years in product</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-value">3</span>
            <span class="stat-label text-muted">AI-native products shipped</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-value">B2B</span>
            <span class="stat-label text-muted">SaaS focus</span>
          </div>
        </div>
      </div>

      <div class="hero-visual">
        <div class="portrait-frame">
          <Image
            src={portrait}
            alt="Marion Dupont, Product Manager"
            width={480}
            height={580}
            class="portrait-img"
            loading="eager"
          />
          <div class="portrait-overlay"></div>
        </div>
      </div>
    </div>

    <div class="hero-scroll" aria-hidden="true">
      <span class="scroll-line"></span>
    </div>
  </section>

  <!-- ── Value Props ───────────────────────────────────────────────────── -->
  <section class="value-props">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">What I bring to the table</h2>
        <p class="section-sub text-muted">
          Three domains. One through-line: making complex data systems feel effortless.
        </p>
      </div>

      <div class="props-grid">
        <article class="card prop-card">
          <div class="prop-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
            </svg>
          </div>
          <h3>AI product strategy</h3>
          <p class="text-muted">
            Defining where AI creates durable value vs. hype. I've shipped LLM features that
            users actually rely on — not demos that fade after launch.
          </p>
          <a href="/ai-expertise" class="prop-link">
            Explore my AI work
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </article>

        <article class="card prop-card">
          <div class="prop-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>
            </svg>
          </div>
          <h3>Embedded analytics</h3>
          <p class="text-muted">
            Building analytics that live inside the product, not beside it. From chart libraries
            to semantic layers — I speak both PM and data engineering.
          </p>
          <a href="/portfolio" class="prop-link">
            See case studies
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </article>

        <article class="card prop-card">
          <div class="prop-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/>
            </svg>
          </div>
          <h3>0→1 execution</h3>
          <p class="text-muted">
            From fuzzy problem space to shipped product. I thrive in ambiguity and have a track
            record of leading cross-functional teams from discovery to revenue impact.
          </p>
          <a href="/my-story" class="prop-link">
            Read my story
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </article>
      </div>
    </div>
  </section>

  <!-- ── Selected Work ─────────────────────────────────────────────────── -->
  <section class="selected-work">
    <div class="container">
      <div class="section-header section-header--row">
        <div>
          <h2 class="section-title">Selected work</h2>
          <p class="section-sub text-muted">A few stories worth telling.</p>
        </div>
        <a href="/portfolio" class="btn btn-outline">All projects</a>
      </div>

      <div class="work-list">
        <a href="/portfolio" class="work-item card">
          <div class="work-meta">
            <span class="tag accent">AI · Analytics</span>
            <span class="work-year text-muted">2024</span>
          </div>
          <h3 class="work-title">Natural Language to Insight</h3>
          <p class="text-muted work-desc">
            Shipped an LLM-powered query interface on top of a multi-tenant analytics platform,
            reducing time-to-insight by 60% for non-technical users.
          </p>
          <div class="work-arrow">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </a>

        <a href="/portfolio" class="work-item card">
          <div class="work-meta">
            <span class="tag">B2B SaaS · Data</span>
            <span class="work-year text-muted">2023</span>
          </div>
          <h3 class="work-title">Embedded Analytics SDK</h3>
          <p class="text-muted work-desc">
            Designed and launched a white-label analytics SDK adopted by 40+ enterprise clients
            within the first two quarters.
          </p>
          <div class="work-arrow">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </a>

        <a href="/portfolio" class="work-item card">
          <div class="work-meta">
            <span class="tag">Platform · Growth</span>
            <span class="work-year text-muted">2022</span>
          </div>
          <h3 class="work-title">Self-serve Data Onboarding</h3>
          <p class="text-muted work-desc">
            Rebuilt the onboarding flow for a data platform from zero, cutting time-to-value
            from 3 weeks to under 2 days.
          </p>
          <div class="work-arrow">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ── CTA ──────────────────────────────────────────────────────────── -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-box card">
        <div class="cta-content">
          <h2>Let's build something that matters</h2>
          <p class="text-muted">
            Whether you're scaling a data product, rethinking your AI strategy, or need
            a PM who can hold a conversation with your data team — I'd love to hear from you.
          </p>
          <a href="mailto:hello@mariondupont.com" class="btn btn-primary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"/></svg>
            Get in touch
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* ── Hero ─────────────────────────────────────────────── */
.hero {
  padding-top: calc(var(--space-20) + var(--space-8));
  padding-bottom: var(--space-20);
  position: relative;
  overflow: hidden;
}

/* Soft navy blob top-right */
.hero::before {
  content: '';
  position: absolute;
  top: -160px;
  right: -160px;
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, rgba(15,23,42,0.06) 0%, transparent 60%);
  pointer-events: none;
}

.hero-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-16);
  align-items: center;
}

/* Badge */
.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-full);
  border: 1.5px solid var(--glass-border);
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  font-size: var(--text-xs);
  font-weight: 500;
  color: var(--color-text);
  margin-bottom: var(--space-6);
}

.badge-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--color-accent);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.35; }
}

/* Title */
.hero-title {
  font-family: var(--font-display);
  font-size: clamp(var(--text-4xl), 5vw, var(--text-6xl));
  font-weight: 800;
  line-height: var(--leading-tight);
  letter-spacing: -0.03em;
  color: var(--color-text);
  margin-bottom: var(--space-6);
}

.hero-em {
  font-style: italic;
  font-weight: 300;
  color: var(--color-accent);
}

.hero-subtitle {
  font-size: var(--text-lg);
  color: var(--color-text-muted);
  line-height: var(--leading-normal);
  max-width: 480px;
  margin-bottom: var(--space-8);
}

.hero-actions {
  display: flex;
  gap: var(--space-3);
  flex-wrap: wrap;
  margin-bottom: var(--space-12);
}

/* Stats */
.hero-stats {
  display: flex;
  align-items: center;
  gap: var(--space-6);
}

.stat-value {
  display: block;
  font-family: var(--font-display);
  font-size: var(--text-2xl);
  font-weight: 800;
  letter-spacing: -0.02em;
  color: var(--color-accent);
}

.stat-label { font-size: var(--text-xs); }

.stat-divider {
  width: 1px;
  height: 32px;
  background: var(--color-border-soft);
}

/* Portrait */
.hero-visual {
  position: relative;
  display: flex;
  justify-content: center;
}

.portrait-frame {
  position: relative;
  border-radius: var(--radius-xl);
  overflow: hidden;
  width: 100%;
  max-width: 420px;
  aspect-ratio: 4/5;
  border: 1.5px solid var(--glass-border);
  box-shadow: var(--glass-shadow);
}

.portrait-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: top center;
}

.portrait-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(15,23,42,0.2) 0%, transparent 55%);
}

/* Scroll indicator */
.hero-scroll {
  position: absolute;
  bottom: var(--space-8);
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.scroll-line {
  width: 1px;
  height: 48px;
  background: linear-gradient(to bottom, var(--color-accent), transparent);
  animation: scrollAnim 2s ease-in-out infinite;
}

@keyframes scrollAnim {
  0%, 100% { opacity: 0.2; transform: scaleY(1); }
  50% { opacity: 0.7; transform: scaleY(1.2); }
}

/* ── Section shared ──────────────────────────────────── */
.section-header {
  text-align: center;
  margin-bottom: var(--space-12);
}

.section-header--row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  text-align: left;
}

.section-title {
  font-family: var(--font-display);
  font-size: var(--text-3xl);
  font-weight: 800;
  letter-spacing: -0.025em;
  margin-bottom: var(--space-3);
}

.section-sub {
  font-size: var(--text-lg);
  max-width: 480px;
  margin-inline: auto;
}

/* ── Value Props ─────────────────────────────────────── */
.value-props {
  background: rgba(255,255,255,0.3);
}

.props-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-6);
}

.prop-card { display: flex; flex-direction: column; gap: var(--space-4); }

.prop-icon {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  background: var(--color-accent-light);
  color: var(--color-accent);
  border: 1px solid var(--color-accent-mid);
}

.prop-card h3 {
  font-family: var(--font-display);
  font-size: var(--text-lg);
  font-weight: 700;
  letter-spacing: -0.015em;
}

.prop-link {
  display: inline-flex;
  align-items: center;
  gap: var(--space-1);
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-accent);
  margin-top: auto;
  transition: gap var(--transition);
}

.prop-link:hover { gap: var(--space-2); }

/* ── Work list ───────────────────────────────────────── */
.selected-work { background: transparent; }
.work-list { display: flex; flex-direction: column; gap: var(--space-4); }

.work-item {
  display: grid;
  grid-template-columns: auto 1fr auto;
  grid-template-rows: auto auto;
  gap: var(--space-2) var(--space-8);
  align-items: center;
  cursor: pointer;
  transition: border-color var(--transition), transform var(--transition);
}

.work-item:hover { transform: translateX(4px); }

.work-meta {
  grid-row: 1;
  grid-column: 1;
  display: flex;
  align-items: center;
  gap: var(--space-3);
}

.work-title {
  grid-row: 1;
  grid-column: 2;
  font-family: var(--font-display);
  font-size: var(--text-xl);
  font-weight: 700;
  letter-spacing: -0.02em;
}

.work-desc {
  grid-row: 2;
  grid-column: 1 / 3;
  font-size: var(--text-sm);
}

.work-year { font-size: var(--text-xs); }

.work-arrow {
  grid-row: 1 / 3;
  grid-column: 3;
  color: var(--color-text-muted);
  transition: color var(--transition), transform var(--transition);
}

.work-item:hover .work-arrow {
  color: var(--color-accent);
  transform: translateX(4px);
}

/* ── CTA ─────────────────────────────────────────────── */
.cta-section { background: transparent; }

.cta-box {
  text-align: center;
  padding: var(--space-16) var(--space-8);
}

.cta-content { position: relative; z-index: 1; }

.cta-box h2 {
  font-family: var(--font-display);
  font-size: var(--text-3xl);
  font-weight: 800;
  letter-spacing: -0.025em;
  margin-bottom: var(--space-4);
}

.cta-box p {
  max-width: 520px;
  margin-inline: auto;
  margin-bottom: var(--space-8);
  font-size: var(--text-lg);
}

/* ── Responsive ──────────────────────────────────────── */
@media (max-width: 1024px) {
  .props-grid { grid-template-columns: 1fr 1fr; }
}

@media (max-width: 768px) {
  .hero-inner {
    grid-template-columns: 1fr;
    gap: var(--space-12);
  }

  .hero-visual { order: -1; }
  .portrait-frame { max-width: 300px; }
  .props-grid { grid-template-columns: 1fr; }

  .section-header--row {
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-4);
  }

  .work-item {
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto auto;
  }

  .work-title { grid-column: 1; grid-row: 2; }
  .work-desc  { grid-column: 1 / 3; grid-row: 3; }
  .work-meta  { grid-row: 1; }
  .work-arrow { grid-row: 1 / 2; grid-column: 2; }
}
</style>
