---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ProjectCard from '../components/ProjectCard.astro';
import BrowserMock from '../components/BrowserMock.astro';
import PhoneMock from '../components/PhoneMock.astro';
import portrait from '../assets/portrait-Marion.jpg';

const testimonials = [
  {
    quote: "C'est probablement l'une des collaborations produit / engineering les plus riches que j'ai connues. Ce que j'ai beaucoup apprécié avec Marion, c'est qu'elle cherche vraiment à comprendre : les utilisateurs, le marché, la concurrence, mais aussi les impacts côté engineering. Ça rend les discussions très efficaces, et surtout beaucoup plus intéressantes pour un développeur.",
    name: 'Jérémy Pinhel',
    role: 'Senior Software Engineer · Toucan',
  },
  {
    quote: "Marion fait clairement partie des PM avec qui on a envie de travailler. Elle fait preuve d'une grande maturité produit et sait arbitrer avec justesse sous pression marché, en alignant enjeux business, besoins utilisateurs et qualité de ce qui est délivré, sans jamais perdre de vue l'humain au sein de ses équipes. Elle collabore très étroitement avec le design et sait en faire un véritable levier d'impact produit. Un vrai plaisir de collaborer avec elle au quotidien.",
    name: 'Sara Tissenier',
    role: 'Senior Product Designer',
  },
  {
    quote: "J'ai managé Marion pendant deux ans chez Entourage. Elle est arrivée en stage, elle est repartie PM aguerrie après avoir piloté la refonte complète de notre app mobile native iOS / Android. Une évolution qu'elle a portée avec autant d'exigence que d'humilité. Au-delà de la rigueur, il y a aussi un vrai sens du collectif. Marion adore vraiment son métier, et cette passion tire toute l'équipe vers le haut. On a tous besoin d'une Marion dans son équipe !",
    name: 'Alexandre Mac',
    role: 'Chief Product Officer · Entourage',
  },
];
---

<BaseLayout title="Marion Débonnaire — Senior Product Manager at the edge of AI">
  <!-- ░░ Hero ░░ -->
  <section class="hero gradient-hero nav-bleed">
    <div class="hero-inner">
      <div class="hero-text">
        <h1>Senior Product Manager<br>at <span class="accent">the edge of AI.</span></h1>
        <p class="lead">At the intersection of product, AI and data. I turn complex analytics into conversational, human experiences.</p>
        <div class="stats">
          <div class="stat"><div class="num">6+ years</div>PRODUCT</div>
          <div class="stat"><div class="num">AI · Data</div>FOCUS</div>
          <div class="stat"><div class="num">SaaS · Mobile</div>B2B · B2C</div>
        </div>
      </div>
      <div class="hero-portrait">
        <div class="outline" aria-hidden="true"></div>
        <Image src={portrait} alt="Portrait of Marion Débonnaire" class="portrait" widths={[360, 560, 720]} sizes="(max-width: 860px) 90vw, 420px" />
      </div>
    </div>
  </section>

  <!-- ░░ Selected Work ░░ -->
  <section class="selected-work">
    <div class="wrap header-wrap">
      <SectionHeader title="Selected Work" />
    </div>
    <ProjectCard
      index="01"
      tags={['AI', 'Conversational UX']}
      title="Toucan AI"
      blurb="An AI-native, conversational analytics platform, rebuilt from scratch so end users can simply ask a question and instantly get the answer."
      metricValue="15+ qualified opportunities"
      metricSuffix="in the first month of beta"
      href="#"
      pad="48px 32px 72px"
    >
      <BrowserMock slot="media" variant="chart" />
    </ProjectCard>
  </section>

  <!-- ░░ Project 02 · Entourage ░░ -->
  <section class="band lilac">
    <ProjectCard
      index="02"
      tags={['Mobile', 'Social Impact']}
      title="Entourage App Redesign"
      blurb="Repositioning a non-profit's app from donation-centric to a social connection platform built around events, communities and education."
      metricValue="170,000 users"
      metricSuffix="on the app"
      href="#"
      reverse
    >
      <PhoneMock slot="media" />
    </ProjectCard>
  </section>

  <!-- ░░ Project 03 · Self-service Dashboard ░░ -->
  <section class="band cream">
    <ProjectCard
      index="03"
      tags={['B2B SaaS', 'Acquisition']}
      title="Self-service Dashboard"
      blurb="A pick-and-choose dashboard editor that lets business users customize their embedded analytics, with no technical knowledge required."
      metricValue="36% of SQL-to-QSO conversions"
      metricSuffix="in 2025"
      href="/portfolio/self-service-dashboard"
    >
      <BrowserMock slot="media" variant="dashboard" soft urlWidth="40%" />
    </ProjectCard>
  </section>

  <!-- ░░ Kind Words ░░ -->
  <section class="kind-words">
    <div class="wrap">
      <div class="kw-header"><SectionHeader title="Kind Words from Teammates" /></div>
      <div class="kw-grid">
        {testimonials.map(t => (
          <figure class="quote-card">
            <blockquote>{t.quote}</blockquote>
            <figcaption class="author">
              <span class="avatar" aria-hidden="true"></span>
              <span>
                <span class="author-name">{t.name}</span>
                <span class="author-role">{t.role}</span>
              </span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
/* Hero */
.hero-inner {
  position: relative;
  max-width: var(--max-content);
  margin: 0 auto;
  padding: 40px var(--gutter) 72px;
  display: grid;
  grid-template-columns: 1.35fr 1fr;
  gap: 56px;
  align-items: center;
}
.hero-text h1 {
  font-size: 62px;
  font-weight: 600;
  line-height: 1.04;
  letter-spacing: -0.025em;
  margin: 0 0 24px;
}
.hero-text h1 .accent { color: var(--color-accent); }
.lead {
  font-size: 19px;
  line-height: 1.6;
  color: var(--color-muted-2);
  max-width: 30ch;
  margin: 0 0 32px;
}
.stats {
  display: flex;
  gap: 36px;
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--color-meta);
  border-top: var(--border-hairline);
  padding-top: 22px;
}
.stat .num {
  font-family: var(--font-display);
  font-size: 22px;
  font-weight: 600;
  color: var(--color-ink);
  white-space: nowrap;
  margin-bottom: 7px;
}
.hero-portrait { position: relative; margin: 0 16px 16px 0; }
.hero-portrait .outline {
  position: absolute;
  inset: 18px -16px -16px 18px;
  border: 1.5px solid var(--color-accent);
  border-radius: var(--radius-img);
}
.hero-portrait .portrait {
  position: relative;
  width: 100%;
  height: auto;
  border-radius: var(--radius-img);
  box-shadow: var(--shadow-portrait);
}

/* Sections */
.selected-work { background: var(--color-bg-white); }
.header-wrap { padding-top: 64px; }
.band.lilac { background: var(--color-bg-lilac); }
.band.cream { background: var(--color-bg-cream); }

/* Kind Words */
.kind-words { background: var(--color-bg-white); }
.kind-words .wrap { padding-block: 72px; }
.kw-header { margin-bottom: 44px; }
.kw-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; }
.quote-card { margin: 0; border-top: 2px solid var(--color-accent); padding-top: 22px; }
.quote-card blockquote {
  font-size: 17px;
  line-height: 1.6;
  color: var(--color-body);
  margin: 0 0 22px;
}
.author { display: flex; align-items: center; gap: 12px; }
.avatar { width: 42px; height: 42px; border-radius: 50%; background: var(--color-bg-lilac); flex-shrink: 0; }
.author-name { display: block; font-family: var(--font-display); font-weight: 600; font-size: 15px; color: var(--color-ink); }
.author-role { display: block; font-family: var(--font-mono); font-size: 11px; color: var(--color-meta); }

@media (max-width: 860px) {
  .hero-inner { grid-template-columns: 1fr; gap: 40px; }
  .hero-text h1 { font-size: clamp(40px, 9vw, 62px); }
  .hero-portrait { order: -1; margin: 0; max-width: 420px; }
  .kw-grid { grid-template-columns: 1fr; gap: 32px; }
}
</style>
