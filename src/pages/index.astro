<link rel="stylesheet" href="https://unpkg.com/github-calendar@latest/dist/github-calendar-responsive.css" />

<script is:inline>
  (function loadCalendar() {
    const cal = document.querySelector('.calendar');

    // Watch for injected content and strip unwanted elements
    const observer = new MutationObserver(function() {
      cal.querySelectorAll('h2, [aria-hidden="true"] + h2, a').forEach(function(el) {
        const text = el.textContent.trim();
        if (text.includes('Skip') || text.includes('Contribution Graph')) {
          el.remove();
        }
      });
      // Shrink Less / More legend text
      cal.querySelectorAll('*').forEach(function(el) {
        const text = el.textContent.trim();
        if ((text === 'Less' || text === 'More') && el.children.length === 0) {
          el.style.fontSize = '9px';
          el.style.color = '#A0A8B0';
        }
        // Remove all borders from injected elements
        el.style.border = 'none';
        el.style.boxShadow = 'none';
        el.style.outline = 'none';
        // Add inner left padding to the graph container
        if (el.tagName === 'DIV' && el.querySelector('svg')) {
          el.style.paddingLeft = '12px';
        }
      });
    });
    observer.observe(cal, { childList: true, subtree: true });

    const script = document.createElement('script');
    script.src = 'https://unpkg.com/github-calendar@latest/dist/github-calendar.min.js';
    script.onload = function () {
      GitHubCalendar('.calendar', 'MarionDebo', {
        responsive: true,
        tooltips: true,
        global_stats: false,
        year: 2026,
      });
    };
    document.head.appendChild(script);
  })();
</script>
