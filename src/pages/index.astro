---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import portrait from '../assets/portrait-Marion.jpg';
import saraTissenier from '../assets/sara-tissenier.jpeg';
import jeremyPinhel from '../assets/jeremy-pinhel.jpeg';
import christinaStumpf from '../assets/christina-stumpf.jpeg';
import alexandreMac from '../assets/alexandre-mac.jpeg';

const teammates = [
  {
    photo: jeremyPinhel.src,
    quote: "C'est probablement l'une des collaborations produit / engineering les plus riches que j'ai connues. Ce que j'ai beaucoup apprécié avec Marion, c'est qu'elle cherche vraiment à comprendre : les utilisateurs, le marché, la concurrence, mais aussi les impacts côté engineering. Ça rend les discussions très efficaces, et surtout beaucoup plus intéressantes pour un développeur.",
    name: 'Jérémy Pinhel',
    role: 'Senior Software Engineer',
    context: 'Same team at Toucan in 2026',
    date: 'May 4, 2026',
    linkedin: 'https://www.linkedin.com/in/jeremypinhel/',
  },
  {
    photo: saraTissenier.src,
    quote: "Marion fait clairement partie des PM avec qui on a envie de travailler. Elle fait preuve d'une grande maturité produit et sait arbitrer avec justesse sous pression marché, en alignant enjeux business, besoins utilisateurs et qualité de ce qui est délivré, sans jamais perdre de vue l'humain au sein de ses équipes. Elle collabore très étroitement avec le design et sait en faire un véritable levier d'impact produit. Un vrai plaisir de collaborer avec elle au quotidien.",
    name: 'Sara Tissenier',
    role: 'Senior Product Designer, AI product',
    context: 'Same team at Toucan in 2025',
    date: 'January 7, 2026',
    linkedin: 'https://www.linkedin.com/in/saratissenier/',
  },
  {
    photo: alexandreMac.src,
    quote: "J'ai managé Marion pendant deux ans chez Entourage. Elle est arrivée en stage, elle est repartie PM aguerrie après avoir piloté la refonte complète de notre app mobile native iOS / Android. Une évolution qu'elle a portée avec autant d'exigence que d'humilité. Au-delà de la rigueur, il y a aussi un vrai sens du collectif. Marion adore vraiment son métier, et cette passion tire toute l'équipe vers le haut. On a tous besoin d'une Marion dans son équipe !",
    name: 'Alexandre Mac',
    role: 'Chief Product Officer @ Entourage',
    context: 'Direct manager at Entourage in 2023',
    date: undefined,
    linkedin: 'https://www.linkedin.com/in/alexandre-mac/',
  },
  {
    photo: christinaStumpf.src,
    quote: "Marion worked on Content Marketing tasks for the French market while being in my SEO team at FlixBus. She is very passionate about anything she does. She has lots of great and relevant ideas that drive the business forward and pushes all her projects with great vigour. On top of that, Marion is a great team player and a fun person to be around. Thank you, Marion, for all your incredible work, dedication, reliability and spirit!",
    name: 'Christina Stumpf',
    role: 'Project Lead Legal Tech @ Flix',
    context: 'Direct manager at FlixBus in 2018',
    date: 'June 15, 2018',
    linkedin: 'https://www.linkedin.com/in/christina-stumpf-584a8873/',
  },
];
---

<BaseLayout
  title="Marion Débonnaire — PM · AI-native Analytics"
  description="Product Manager specialised in AI-native embedded analytics SaaS. I turn data complexity into product clarity."
>

  <!-- ── Hero ─────────────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-content">

        <h1 class="hero-title">
          Senior Product Manager<br />
          <em class="hero-em">at the edge of AI.</em>
        </h1>

        <p class="hero-subtitle">
          6 years shipping SaaS and mobile products, at the intersection of embedded analytics, Artificial Intelligence, and user obsession. Currently building the next generation of AI-native analytics at Toucan.
        </p>

        <div class="hero-actions">
          <a href="/portfolio" class="btn btn-primary">See my work</a>
          <a href="/my-story" class="btn btn-outline">My story</a>
        </div>

        <div class="hero-stats">
          <div class="stat">
            <span class="stat-value">6+</span>
            <span class="stat-label text-muted">Years in product</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-value">SaaS & Mobile</span>
            <span class="stat-label text-muted">SaaS and mobile apps</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-value">B2B & B2C</span>
            <span class="stat-label text-muted">Enterprise to social impact</span>
          </div>
        </div>
      </div>

      <div class="hero-visual">
        <div class="portrait-frame">
          <Image
            src={portrait}
            alt="Marion Débonnaire, Product Manager"
            width={480}
            height={580}
            class="portrait-img"
            loading="eager"
          />
          <div class="portrait-overlay"></div>
        </div>
      </div>
    </div>

    <div class="hero-scroll" aria-hidden="true">
      <span class="scroll-line"></span>
    </div>
  </section>

  <!-- ── Value Props ───────────────────────────────────────────────────── -->
  <section class="value-props">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">What I bring to the table</h2>
        <p class="section-sub text-muted">
          Three domains. One through-line: turning complex problems into simple, impactful product experiences.
        </p>
      </div>

      <div class="props-grid">
        <article class="card prop-card">
          <div class="prop-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5"/><circle cx="12" cy="12" r="1"/></svg>
          </div>
          <h3>Business-driven product thinking</h3>
          <p class="text-muted">
            I connect product decisions to business outcomes from day one. Whether it's framing an acquisition problem, aligning stakeholders around a roadmap, or deciding what NOT to build, I think in terms of impact, not output.
          </p>
          <a href="/my-story" class="prop-link">
            Read my story
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </article>

        <article class="card prop-card">
          <div class="prop-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="5" cy="6" r="2"/><circle cx="5" cy="18" r="2"/><circle cx="19" cy="12" r="2"/><path d="M7 6h4a3 3 0 0 1 3 3v0M7 18h4a3 3 0 0 0 3-3v0M14 12h3"/></svg>
          </div>
          <h3>AI product design</h3>
          <p class="text-muted">
            Nearly a year shipping an AI-native analytics platform from scratch. I know what it takes to design trust into probabilistic products, structure conversational experiences, and work with a sovereign AI stack (Mistral + Scaleway).
          </p>
          <a href="/ai-expertise" class="prop-link">
            Explore my AI work
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </article>

        <article class="card prop-card">
          <div class="prop-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v16a2 2 0 0 0 2 2h16"/><rect x="7" y="11" width="3" height="6" rx="0.5"/><rect x="13" y="7" width="3" height="10" rx="0.5"/></svg>
          </div>
          <h3>Analytics expertise</h3>
          <p class="text-muted">
            Three years building analytics products that live inside SaaS platforms, not beside them. I understand the full stack: chart libraries, white-label UX, self-service, and the business models that go with them.
          </p>
          <a href="/portfolio" class="prop-link">
            See case studies
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </article>
      </div>
    </div>
  </section>

  <!-- ── Selected Work ─────────────────────────────────────────────────── -->
  <section class="selected-work">
    <div class="container">
      <div class="section-header section-header--row">
        <div>
          <h2 class="section-title">Selected work</h2>
          <p class="section-sub text-muted">A few stories worth telling.</p>
        </div>
        <a href="/portfolio" class="btn btn-outline">All projects</a>
      </div>

      <div class="work-grid">

        <a href="/portfolio/toucan-ai" class="work-card card">
          <div class="work-meta">
            <span class="tag">AI · Conversational UX</span>
            <span class="work-year text-muted">2026</span>
          </div>
          <h3 class="work-title">Toucan AI</h3>
          <p class="text-muted work-desc">
            Contributed to rebuilding Toucan's platform from scratch, AI-native. Defined the chart and dashboard creation experience for makers and end users.
          </p>
          <div class="work-arrow">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </a>

        <a href="/portfolio/self-service-dashboard" class="work-card card">
          <div class="work-meta">
            <span class="tag">B2B SaaS · Acquisition</span>
            <span class="work-year text-muted">2025</span>
          </div>
          <h3 class="work-title">Self-service Dashboard</h3>
          <p class="text-muted work-desc">
            Turned a critical acquisition blocker into a self-service feature, determining 36% of SQL-to-QSO conversions.
          </p>
          <div class="work-arrow">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </a>

        <a href="/portfolio/entourage-app" class="work-card card">
          <div class="work-meta">
            <span class="tag">Mobile · Social Impact</span>
            <span class="work-year text-muted">2023</span>
          </div>
          <h3 class="work-title">Entourage App Redesign</h3>
          <p class="text-muted work-desc">
            Repositioned a donation-centric mobile app around social connection. Now 170,000 users across 30 cities.
          </p>
          <div class="work-arrow">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- ── Kind Words ──────────────────────────────────────────────────── -->
  <section class="kind-words">
    <div class="container">
      <div class="section-header">
        <h2 class="section-title">Kind words from teammates</h2>
        <p class="section-sub text-muted">From people I've shipped with.</p>
      </div>

      <div class="kw-grid">
        {teammates.map(t => (
          <figure class="card kw-card">
            <div class="quote-mark" aria-hidden="true">"</div>
            <blockquote class="kw-quote">{t.quote}</blockquote>
            <figcaption class="kw-author">
              {t.photo
                ? t.linkedin
                  ? <a href={t.linkedin} target="_blank" rel="noopener noreferrer" aria-label={`${t.name} on LinkedIn`}>
                      <img src={t.photo} alt={t.name} class={`kw-avatar${t.name === 'Sara Tissenier' ? ' kw-avatar--bordered' : ''}`} width="56" height="56" loading="lazy" />
                    </a>
                  : <img src={t.photo} alt={t.name} class="kw-avatar" width="56" height="56" loading="lazy" />
                : <div class="kw-avatar kw-avatar--initials" aria-hidden="true">{t.initials}</div>
              }
              {t.linkedin
                ? <a href={t.linkedin} target="_blank" rel="noopener noreferrer" class="kw-identity kw-identity--link">
                    <span class="kw-name">{t.name}</span>
                    <span class="kw-role text-muted">{t.role}</span>
                    {t.context && <span class="kw-date text-muted">{t.context}</span>}
                  </a>
                : <div class="kw-identity">
                    <span class="kw-name">{t.name}</span>
                    <span class="kw-role text-muted">{t.role}</span>
                    {t.context && <span class="kw-date text-muted">{t.context}</span>}
                  </div>
              }
            </figcaption>
          </figure>
        ))}
      </div>

      <div class="kw-footer">
        <a href="https://www.linkedin.com/in/marion-debonnaire/" target="_blank" rel="noopener noreferrer" class="kw-linkedin-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          All recommendations available on LinkedIn
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
/* ── Hero ─────────────────────────────────────────────── */
.hero {
  padding-top: calc(var(--space-20) + var(--space-8));
  padding-bottom: var(--space-20);
  position: relative;
  overflow: hidden;
}

/* Soft navy blob top-right */
.hero::before {
  content: '';
  position: absolute;
  top: -160px;
  right: -160px;
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, rgba(15,23,42,0.06) 0%, transparent 60%);
  pointer-events: none;
}

.hero-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-16);
  align-items: center;
}

/* Badge */
.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-full);
  border: 1.5px solid var(--glass-border);
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  font-size: var(--text-xs);
  font-weight: 500;
  color: var(--color-text);
  margin-bottom: var(--space-6);
}

.badge-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--color-accent);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.35; }
}

/* Title */
.hero-title {
  font-family: var(--font-display);
  font-size: clamp(var(--text-4xl), 5vw, var(--text-6xl));
  font-weight: 500;
  line-height: 1.08;
  letter-spacing: -0.02em;
  color: var(--color-text);
  margin-bottom: var(--space-6);
}

.hero-em {
  font-style: italic;
  font-weight: 400;
  color: var(--color-accent);
}

.hero-subtitle {
  font-size: var(--text-lg);
  color: var(--color-text-muted);
  line-height: var(--leading-normal);
  max-width: 480px;
  margin-bottom: var(--space-8);
}

.hero-actions {
  display: flex;
  gap: var(--space-3);
  flex-wrap: wrap;
  margin-bottom: var(--space-12);
}

/* Stats */
.hero-stats {
  display: flex;
  align-items: center;
  gap: var(--space-6);
}

.stat-value {
  display: block;
  font-family: var(--font-ui);
  font-size: var(--text-xl);
  font-weight: 700;
  letter-spacing: -0.02em;
  color: var(--color-accent);
}

.stat-label { font-size: var(--text-xs); line-height: 1.3; }

.stat-divider {
  width: 1px;
  height: 32px;
  background: var(--color-border-soft);
}

/* Portrait */
.hero-visual {
  position: relative;
  display: flex;
  justify-content: center;
}

.portrait-frame {
  position: relative;
  border-radius: var(--radius-xl);
  overflow: hidden;
  width: 100%;
  max-width: 380px;
  aspect-ratio: 4/5;
  border: 1.5px solid var(--glass-border);
  box-shadow: var(--glass-shadow);
}

.portrait-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: top center;
}

.portrait-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(15,23,42,0.2) 0%, transparent 55%);
}

/* Scroll indicator */
.hero-scroll {
  position: absolute;
  bottom: var(--space-8);
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.scroll-line {
  width: 1px;
  height: 48px;
  background: linear-gradient(to bottom, var(--color-accent), transparent);
  animation: scrollAnim 2s ease-in-out infinite;
}

@keyframes scrollAnim {
  0%, 100% { opacity: 0.2; transform: scaleY(1); }
  50% { opacity: 0.7; transform: scaleY(1.2); }
}

/* ── Section shared ──────────────────────────────────── */
.section-header {
  text-align: center;
  margin-bottom: var(--space-12);
}

.section-header--row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  text-align: left;
}

.section-title {
  font-family: var(--font-display);
  font-size: var(--text-4xl);
  font-weight: 500;
  letter-spacing: -0.015em;
  margin-bottom: var(--space-3);
}

.section-sub {
  font-size: var(--text-lg);
  max-width: 480px;
  margin-inline: auto;
}

/* ── Value Props ─────────────────────────────────────── */
.value-props {
  background: rgba(255,255,255,0.3);
}

.props-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-6);
}

.prop-card { display: flex; flex-direction: column; gap: var(--space-4); }

.prop-icon {
  width: 46px;
  height: 46px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  background: var(--color-accent-light);
  border: 1px solid var(--color-accent-mid);
  color: var(--color-accent);
}

.prop-card h3 {
  font-family: var(--font-ui);
  font-size: var(--text-lg);
  font-weight: 700;
  letter-spacing: -0.015em;
}

.prop-link {
  display: inline-flex;
  align-items: center;
  gap: var(--space-1);
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-accent);
  margin-top: auto;
  transition: gap var(--transition);
}

.prop-link:hover { gap: var(--space-2); }

/* ── Work grid ───────────────────────────────────────── */
.selected-work { background: transparent; }

.work-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-6);
}

.work-card {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  text-decoration: none;
  transition: border-color var(--transition), transform var(--transition);
}

.work-card:hover { transform: translateY(-2px); }

.work-meta {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  flex-wrap: wrap;
}

.work-title {
  font-family: var(--font-ui);
  font-size: var(--text-xl);
  font-weight: 700;
  letter-spacing: -0.02em;
}

.work-desc {
  font-size: var(--text-sm);
  flex: 1;
}

.work-year { font-size: var(--text-xs); }

.work-arrow {
  align-self: flex-end;
  color: var(--color-text-muted);
  transition: color var(--transition), transform var(--transition);
}

.work-card:hover .work-arrow {
  color: var(--color-accent);
  transform: translateX(4px);
}

/* ── CTA ─────────────────────────────────────────────── */
.cta-section { background: transparent; }

.cta-box {
  text-align: center;
  padding: var(--space-16) var(--space-8);
}

.cta-content { position: relative; z-index: 1; }

.cta-box h2 {
  font-family: var(--font-display);
  font-size: var(--text-4xl);
  font-weight: 500;
  letter-spacing: -0.015em;
  margin-bottom: var(--space-4);
}

.cta-box p {
  max-width: 520px;
  margin-inline: auto;
  margin-bottom: var(--space-8);
  font-size: var(--text-lg);
}

/* ── Kind Words ─────────────────────────────────────── */
.kw-footer {
  margin-top: var(--space-8);
  text-align: center;
}

.kw-linkedin-link {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--text-sm);
  font-weight: 600;
  color: var(--color-text-muted);
  transition: color var(--transition);
}

.kw-linkedin-link svg { color: #0077b5; }

.kw-linkedin-link:hover { color: #0077b5; }


.kind-words { background: rgba(255,255,255,0.28); }

.kw-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-6);
}

.kw-card {
  display: flex;
  flex-direction: column;
  gap: var(--space-5);
}

.quote-mark {
  font-size: 3.5rem;
  line-height: 1;
  color: var(--color-accent);
  opacity: 0.2;
  font-family: Georgia, serif;
  margin-bottom: calc(-1 * var(--space-4));
}

.kw-quote {
  font-size: var(--text-base);
  line-height: var(--leading-normal);
  color: var(--color-text-muted);
  font-style: italic;
  flex: 1;
}

.kw-author {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  margin-top: var(--space-2);
  padding-top: var(--space-4);
  border-top: 1px solid var(--color-border-soft);
}

.kw-avatar {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  object-fit: cover;
  flex-shrink: 0;
  border: 1.5px solid var(--glass-border);
}

.kw-avatar--bordered {
  border: 1.5px solid #d0d0d0;
}

.kw-avatar--initials {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-accent-light);
  color: var(--color-accent);
  font-family: var(--font-ui);
  font-weight: 700;
  font-size: 0.875rem;
  letter-spacing: 0.05em;
  border: 1.5px solid var(--color-accent-mid);
}

.kw-identity {
  display: block;
}

.kw-identity--link {
