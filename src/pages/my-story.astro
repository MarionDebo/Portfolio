---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Tag from '../components/Tag.astro';
import teamPhoto from '../assets/Photo-groupe-maison.jpeg';

const chapters = [
  {
    label: 'CH. 01 · THE SPARK',
    title: 'Falling for the problem',
    body: "I didn't set out to manage products. I set out to understand why people abandon the very thing that was supposed to help them. Product was simply where that question lived — at the seam between empathy, business and engineering. I've been standing on that seam ever since.",
  },
  {
    label: 'CH. 02 · MISSION-DRIVEN',
    title: 'Entourage — product with a purpose',
    body: "At Entourage I helped move a non-profit's app away from being a donation box and toward a place where people genuinely connect — events, communities, learning. 170,000 people now use it. The lesson that stuck: impact doesn't happen by accident. It has to be designed.",
    metric: { value: '170,000', suffix: 'people on the app' },
  },
  {
    label: 'CH. 03 · INTO THE DATA',
    title: 'Toucan — making analytics human',
    body: "Then came analytics. At Toucan I built a self-service dashboard editor so business users could shape their own embedded analytics — no SQL, no waiting on a data team. It pushed SQL-to-QSO conversion to 36%. I learned that the best data product is the one that disappears behind the decision it helps you make.",
    metric: { value: '36%', suffix: 'SQL-to-QSO conversion' },
  },
  {
    label: 'CH. 04 · AI-NATIVE · TODAY',
    title: 'Betting on the conversation',
    body: "Today I'm rebuilding analytics around conversation. Toucan AI lets people just ask — and get the answer, not a chart to decipher. It's the edge of AI, and it's exactly where I want to be: making powerful technology feel obvious, even kind.",
    dark: true,
  },
];

const principles = [
  { n: '01', title: 'Start with the job, not the feature', body: 'Understand the real job someone is hiring the product to do. Features are just one possible answer to it.' },
  { n: '02', title: 'Ship to learn', body: 'Evidence beats opinion. Build the smallest thing that teaches you something real, then let it change your mind.' },
  { n: '03', title: 'Make the technology disappear', body: 'Especially with AI. The best experience asks nothing of the user and quietly does the hard part for them.' },
  { n: '04', title: 'The team is the product', body: 'A clear, trusting, curious team ships better products than any roadmap ever could. Protect it fiercely.', dark: true },
];
---

<BaseLayout title="My Story — Marion Débonnaire">
  <!-- ░░ Hero ░░ -->
  <section class="story-hero">
    <div class="watermark" aria-hidden="true">product</div>
    <div class="hero-inner">
      <p class="eyebrow">MY&nbsp;STORY</p>
      <h1>Not a résumé.<br>A throughline.</h1>
      <p class="lead">I'm Marion, a product manager who fell for the messy middle, where user needs, business reality and what's technically possible all collide. Six years in, the throughline hasn't changed: turn complexity into something a human can actually use. Lately, that means building at the edge of AI.</p>
      <div class="pills">
        <Tag size="pill">Product</Tag>
        <Tag size="pill">AI · Data</Tag>
        <Tag size="pill">Human-first</Tag>
      </div>
    </div>
  </section>

  <!-- ░░ The Journey ░░ -->
  <section class="journey">
    <div class="journey-inner">
      <SectionHeader title="The Journey" subline="FOUR CHAPTERS · ONE DIRECTION OF TRAVEL" />
      <div class="timeline">
        <div class="rail" aria-hidden="true"></div>
        {chapters.map(ch => (
          <div class="chapter">
            <div class="node-col"><span class:list={['node', { dark: ch.dark }]} aria-hidden="true"></span></div>
            <div class="chapter-body">
              <div class="chapter-label">{ch.label}</div>
              <h3>{ch.title}</h3>
              <p>{ch.body}</p>
              {ch.metric && (
                <div class="inline-metric">
                  <span class="metric-value">{ch.metric.value}</span>
                  <span class="metric-suffix">{ch.metric.suffix}</span>
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ░░ Product Philosophy ░░ -->
  <section class="philosophy">
    <div class="philosophy-inner">
      <div class="phil-header"><SectionHeader title="Product Philosophy" /></div>
      <div class="phil-grid">
        <div class="phil-left">
          <p class="phil-lead">There's no good product work without a solid team. I care about the craft, but I care more about the people I build it with. That's where the good decisions actually come from.</p>
          <Image src={teamPhoto} alt="The team together after a bike ride" class="team-photo" widths={[480, 720, 960]} sizes="(max-width: 860px) 90vw, 520px" />
          <p class="photo-caption">↑ THE TEAM BEHIND THE WORK</p>
        </div>
        <div class="phil-right">
          {principles.map(p => (
            <div class:list={['principle', { dark: p.dark }]}>
              <div class="principle-num">{p.n}</div>
              <h4>{p.title}</h4>
              <p>{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
/* Hero */
.story-hero {
  margin-top: calc(-1 * var(--nav-bleed));
  padding: 160px var(--gutter) 92px;
  position: relative;
  overflow: hidden;
}
.watermark {
  position: absolute;
  top: 120px;
  left: 50%;
  transform: translateX(-50%);
  font-family: var(--font-display);
  font-weight: 600;
  font-size: clamp(180px, 30vw, 360px);
  line-height: 1;
  color: var(--color-accent);
  opacity: 0.05;
  letter-spacing: -0.04em;
  pointer-events: none;
  user-select: none;
  white-space: nowrap;
}
.hero-inner {
  max-width: 880px;
  margin: 0 auto;
  text-align: center;
  position: relative;
  z-index: 1;
}
.eyebrow {
  font-family: var(--font-mono);
  font-size: 12px;
  letter-spacing: 0.18em;
  color: var(--color-accent);
  margin: 0 0 30px;
}
.story-hero h1 {
  font-size: clamp(48px, 6.4vw, 82px);
  font-weight: 600;
  line-height: 1.03;
  letter-spacing: -0.035em;
  margin: 0 0 32px;
  color: var(--color-ink);
}
.lead {
  font-size: 21px;
  line-height: 1.65;
  color: var(--color-muted-2);
  max-width: 60ch;
  margin: 0 auto;
}
.pills { display: flex; justify-content: center; gap: 14px; margin-top: 40px; flex-wrap: wrap; }

/* Journey timeline */
.journey { background: var(--color-bg-white); }
.journey-inner { max-width: var(--max-nav); margin: 0 auto; padding: 88px var(--gutter) 96px; }
.timeline { position: relative; margin-top: 56px; }
.rail {
  position: absolute;
  left: 9px;
  top: 8px;
  bottom: 8px;
  width: 2px;
  background: linear-gradient(var(--color-accent) 0%, var(--violet-200) 100%);
}
.chapter {
  position: relative;
  display: grid;
  grid-template-columns: 40px 1fr;
  gap: 28px;
  padding-bottom: 56px;
}
.chapter:last-child { padding-bottom: 0; }
.node-col { position: relative; }
.node {
  position: absolute;
  left: 0;
  top: 4px;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: var(--color-accent);
  box-shadow: 0 0 0 5px #fff, 0 0 0 6px rgba(var(--color-accent-rgb), 0.25);
}
.node.dark {
  background: var(--color-dark);
  box-shadow: 0 0 0 5px #fff, 0 0 0 6px rgba(var(--color-accent-rgb), 0.4);
}
.chapter-label {
  font-family: var(--font-mono);
  font-size: 12px;
  letter-spacing: 0.1em;
  color: var(--color-accent);
  margin-bottom: 10px;
}
.chapter-body h3 {
  font-size: 27px;
  font-weight: 600;
  letter-spacing: -0.02em;
  margin: 0 0 14px;
  color: var(--color-ink);
}
.chapter-body p {
  font-size: 18px;
  line-height: 1.65;
  color: var(--color-muted);
  max-width: 62ch;
  margin: 0;
}
.inline-metric {
  display: inline-flex;
  align-items: baseline;
  gap: 10px;
  font-family: var(--font-display);
  margin-top: 18px;
}
.metric-value { font-weight: 600; font-size: 24px; color: var(--color-accent); letter-spacing: -0.02em; }
.metric-suffix { font-size: 14px; color: var(--color-meta); }

/* Product Philosophy */
.philosophy { background: var(--color-bg-lilac); }
.philosophy-inner { max-width: var(--max-content); margin: 0 auto; padding: 88px var(--gutter) 96px; }
.phil-header { margin-bottom: 48px; }
.phil-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
.phil-lead {
  font-family: var(--font-display);
  font-weight: 500;
  font-size: 27px;
  line-height: 1.42;
  letter-spacing: -0.015em;
  color: var(--color-ink);
  margin: 0 0 28px;
}
.team-photo {
  display: block;
  width: 100%;
  height: auto;
  aspect-ratio: 4 / 3;
  object-fit: cover;
  border-radius: 20px;
  box-shadow: var(--shadow-photo);
}
.photo-caption {
  font-family: var(--font-mono);
  font-size: 11px;
  color: #7d6fb0;
  letter-spacing: 0.05em;
  margin: 14px 0 0;
}
.phil-right { display: flex; flex-direction: column; gap: 16px; }
.principle {
  background: var(--color-bg-white);
  border-radius: var(--radius-card);
  padding: 26px 28px;
  border: var(--border-accent-12);
}
.principle.dark { background: var(--color-dark); border: none; }
.principle-num { font-family: var(--font-mono); font-size: 12px; color: var(--color-accent); margin-bottom: 10px; }
.principle.dark .principle-num { color: var(--color-accent-soft); }
.principle h4 {
  font-size: 20px;
  font-weight: 600;
  letter-spacing: -0.01em;
  margin: 0 0 8px;
  color: var(--color-ink);
}
.principle.dark h4 { color: #fff; }
.principle p { font-size: 15.5px; line-height: 1.6; color: var(--color-muted); margin: 0; }
.principle.dark p { color: var(--color-dark-body); }

@media (max-width: 860px) {
  .story-hero { padding: 130px var(--gutter) 72px; }
  .phil-grid { grid-template-columns: 1fr; gap: 40px; }
  .journey-inner, .philosophy-inner { padding-block: 64px; }
}
</style>
