---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import portrait from '../assets/portrait-Marion.jpg';

const timeline = [
  {
    year: '2017',
    title: 'Started as a data analyst',
    body: 'I fell into data by accident — economics degree, a startup internship, and suddenly I was the person everyone asked when the numbers didn\'t add up. I discovered I cared less about the numbers themselves and more about the decisions they enabled.',
  },
  {
    year: '2019',
    title: 'Moved into product',
    body: 'A PM at my company left mid-sprint. I raised my hand. Two weeks later I was running discovery sessions and writing specs. It turned out that understanding the data was a superpower in product — I could validate assumptions faster than anyone on the team.',
  },
  {
    year: '2021',
    title: 'Led my first AI feature',
    body: 'We were building an anomaly detection system. I pushed the team to go further than flagging — to also explain. That was my first real lesson in AI product design: the model is rarely the bottleneck. The user\'s trust is.',
  },
  {
    year: '2022',
    title: 'Rebuilt onboarding from scratch',
    body: 'Time-to-value was killing us. I ran a six-week redesign sprint that cut 34 steps from the onboarding flow and moved completion rates from 12% to 71%. I learned that the best product decision is often removing something, not adding it.',
  },
  {
    year: '2023',
    title: 'Shipped the embedded analytics SDK',
    body: 'This was the most technically complex product I\'ve led — a white-label analytics SDK adopted by 40+ enterprise clients. It forced me to think like a platform PM: every API decision is a contract you\'ll be maintaining for years.',
  },
  {
    year: '2024',
    title: 'Natural language meets the data layer',
    body: 'Shipped a production LLM interface on top of a multi-tenant analytics stack. 800+ evaluation queries. A trust model. A 60% reduction in time-to-insight. And a genuine belief that AI in analytics is still in its first chapter.',
  },
];

const testimonials = [
  {
    quote: "Marion is the rare PM who can walk into a data engineering stand-up and immediately contribute. She understands the trade-offs, asks the right questions, and never pretends ambiguity away.",
    name: 'Julien M.',
    role: 'Engineering Lead, analytics platform',
    initials: 'JM',
  },
  {
    quote: "She's got an exceptional ability to hold both the strategic picture and the user-level detail at the same time. Our NPS jumped 18 points after she led the AI query feature.",
    name: 'Sofia K.',
    role: 'Head of Product, B2B SaaS',
    initials: 'SK',
  },
  {
    quote: "Marion rebuilt our onboarding from the ground up in six weeks. Every decision was tied to evidence, every trade-off was communicated clearly, and the team was energised throughout.",
    name: 'Thomas R.',
    role: 'CEO, early-stage data startup',
    initials: 'TR',
  },
];
---

<BaseLayout
  title="Story — Marion Débonnaire"
  description="From data analyst to AI product manager — the decisions, pivots, and lessons that shaped my approach to building data products."
>
  <!-- Hero -->
  <section class="story-hero">
    <div class="container hero-layout">
      <div class="hero-text">
        <div class="breadcrumb text-muted">
          <a href="/">Home</a>
          <span aria-hidden="true">›</span>
          <span>Story</span>
        </div>

        <h1 class="page-title">
          The long way<br />
          <em class="title-em">into AI product</em>
        </h1>

        <p class="page-sub text-muted">
          I didn't plan to become a PM. I started by understanding data better than most,
          then learned that understanding users was the harder and more interesting problem.
          Seven years later, I sit at the intersection of both.
        </p>

        <div class="hero-chips">
          <span class="tag accent">Product Management</span>
          <span class="tag accent">AI-native</span>
          <span class="tag accent">Embedded Analytics</span>
          <span class="tag">B2B SaaS</span>
          <span class="tag">Based in Paris 🇫🇷</span>
        </div>
      </div>

      <div class="hero-portrait">
        <div class="portrait-wrap">
          <Image
            src={portrait}
            alt="Marion Débonnaire, Product Manager specialised in AI and analytics"
            width={420}
            height={500}
            class="portrait-img"
            loading="eager"
          />
          <div class="portrait-overlay"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Product Philosophy -->
  <section class="philosophy-section">
    <div class="container">
      <h2 class="section-title">My Product Philosophy</h2>
      <p class="section-sub text-muted">
        A few principles I keep coming back to, whatever the product or team.
      </p>

      <div class="philosophy-grid">
        <article class="card philosophy-card">
          <span class="philosophy-icon" aria-hidden="true">💡</span>
          <h3>Philosophy title 1</h3>
          <p class="text-muted">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.</p>
        </article>
        <article class="card philosophy-card">
          <span class="philosophy-icon" aria-hidden="true">🎯</span>
          <h3>Philosophy title 2</h3>
          <p class="text-muted">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.</p>
        </article>
        <article class="card philosophy-card">
          <span class="philosophy-icon" aria-hidden="true">🔍</span>
          <h3>Philosophy title 3</h3>
          <p class="text-muted">Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="timeline-section">
    <div class="container">
      <h2 class="section-title">The journey</h2>
      <p class="section-sub text-muted">
        Not a CV. A sequence of decisions — the ones that stuck, the ones that surprised me,
        and what I learned from each.
      </p>

      <div class="timeline" role="list">
        {timeline.map((item, i) => (
          <div class="timeline-item" role="listitem">
            <div class="timeline-year">
              <span class="year-label">{item.year}</span>
              <div class="year-line" aria-hidden="true"></div>
            </div>
            <div class="timeline-content card">
              <h3 class="timeline-title">{item.title}</h3>
              <p class="text-muted">{item.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Education -->
  <section class="education-section">
    <div class="container">
      <h2 class="section-title">Education</h2>

      <div class="education-list">
        <div class="education-item card">
          <div class="education-year text-muted">2012 – 2015</div>
          <div class="education-content">
            <h3 class="education-degree">Master's in Economics & Management</h3>
            <p class="education-school text-muted">Université Paris-Dauphine</p>
            <p class="text-muted">Specialisation in digital strategy and data analysis. Thesis on behavioural economics in digital markets.</p>
          </div>
        </div>

        <div class="education-item card">
          <div class="education-year text-muted">2010 – 2012</div>
          <div class="education-content">
            <h3 class="education-degree">Bachelor's in Business Administration</h3>
            <p class="education-school text-muted">Université Paris I Panthéon-Sorbonne</p>
            <p class="text-muted">Core curriculum in economics, statistics and organisational theory.</p>
          </div>
        </div>

        <div class="education-item card">
          <div class="education-year text-muted">2023</div>
          <div class="education-content">
            <h3 class="education-degree">AI Product Management — Certificate</h3>
            <p class="education-school text-muted">Reforge</p>
            <p class="text-muted">Intensive programme on building AI-native products, evaluation loops and LLM integration strategy.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="card cta-box">
        <div class="cta-inner">
          <h2>Let's write the next chapter together</h2>
          <p class="text-muted">
            If you're building something at the intersection of AI, data, and product —
            I'd genuinely love to hear about it.
          </p>
          <div class="cta-actions">
            <a href="mailto:hello@mariondebonnaire.com" class="btn btn-primary">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"/></svg>
              Say hello
            </a>
            <a href="/portfolio" class="btn btn-outline">See my work</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
/* Hero */
.story-hero {
  padding-top: calc(var(--space-20) + var(--space-8));
  padding-bottom: var(--space-16);
  background: rgba(255,255,255,0.28);
}

.hero-layout {
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: var(--space-16);
  align-items: center;
}

.breadcrumb {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--text-sm);
  margin-bottom: var(--space-6);
}
.breadcrumb a:hover { color: var(--color-text); }

.page-title {
  font-family: var(--font-display);
  font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
  font-weight: 800;
  letter-spacing: -0.03em;
  line-height: var(--leading-tight);
  margin-bottom: var(--space-6);
}

.title-em {
  font-style: italic;
  font-weight: 300;
  color: var(--color-accent);
}

.page-sub {
  font-size: var(--text-lg);
  max-width: 520px;
  line-height: var(--leading-normal);
  margin-bottom: var(--space-8);
}

.hero-chips {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
}

/* Portrait */
.portrait-wrap {
  border-radius: var(--radius-xl);
  overflow: hidden;
  aspect-ratio: 4/5;
  position: relative;
  border: 1.5px solid var(--glass-border);
  box-shadow: var(--glass-shadow);
}

.portrait-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: top center;
}

.portrait-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(15,23,42,0.15) 0%, transparent 55%);
}

/* Philosophy */
.philosophy-section { background: rgba(255,255,255,0.28); }

.philosophy-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-6);
  margin-top: var(--space-10);
}

.philosophy-card {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.philosophy-icon { font-size: 1.75rem; }

.philosophy-card h3 {
  font-family: var(--font-display);
  font-size: var(--text-lg);
  font-weight: 700;
  letter-spacing: -0.015em;
}

/* Timeline */
.timeline-section { background: transparent; }

.section-title {
  font-family: var(--font-display);
  font-size: var(--text-3xl);
  font-weight: 800;
  letter-spacing: -0.025em;
  margin-bottom: var(--space-3);
}

.section-sub {
  font-size: var(--text-lg);
  max-width: 560px;
  margin-bottom: var(--space-12);
}

.timeline {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.timeline-item {
  display: grid;
  grid-template-columns: 100px 1fr;
  gap: var(--space-8);
  position: relative;
}

.timeline-item:not(:last-child) .year-line {
  position: absolute;
  left: 99px;
  top: var(--space-12);
  bottom: 0;
  width: 1px;
  background: var(--color-border-soft);
}

.timeline-year {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  padding-top: var(--space-8);
  flex-shrink: 0;
  position: relative;
}

.year-label {
  font-size: var(--text-sm);
  font-weight: 700;
  font-family: var(--font-mono);
  color: var(--color-accent);
  padding: var(--space-1) 0;
  position: relative;
  z-index: 1;
}

.timeline-content {
  margin-block: var(--space-4);
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.timeline-title {
  font-family: var(--font-display);
  font-size: var(--text-lg);
  font-weight: 700;
  letter-spacing: -0.01em;
}

/* Values */
.values-section { background: rgba(255,255,255,0.28); }

.values-layout {
  display: grid;
  grid-template-columns: 240px 1fr;
  gap: var(--space-16);
  align-items: start;
}

.values-header .section-title { margin-bottom: 0; }

.values-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-8);
}

.value-label {
  font-family: var(--font-display);
  font-size: var(--text-base);
  font-weight: 700;
  margin-bottom: var(--space-2);
  color: var(--color-text);
}

.value-item p { font-size: var(--text-sm); }

/* Testimonials */
.testimonials-section { background: transparent; }

.testimonials-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-6);
}

.testimonial-card {
  display: flex;
  flex-direction: column;
  gap: var(--space-6);
}

.quote-mark {
  font-size: 3.5rem;
  line-height: 1;
  color: var(--color-accent);
  opacity: 0.25;
  font-family: Georgia, serif;
  margin-bottom: calc(-1 * var(--space-4));
}

.testimonial-quote {
  font-size: var(--text-base);
  line-height: var(--leading-normal);
  color: var(--color-text-muted);
  font-style: italic;
  flex: 1;
}

.testimonial-author {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  padding-top: var(--space-4);
  border-top: 1px solid var(--color-border-soft);
}

.author-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: var(--color-accent);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--text-xs);
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
}

.author-name {
  font-size: var(--text-sm);
  font-weight: 600;
}

.author-role { font-size: var(--text-xs); }

/* Education */
.education-section { background: transparent; }

.education-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  margin-top: var(--space-10);
}

.education-item {
  display: grid;
  grid-template-columns: 120px 1fr;
  gap: var(--space-8);
  align-items: start;
}

.education-year {
  font-size: var(--text-sm);
  font-family: var(--font-mono);
  font-weight: 600;
  padding-top: 3px;
}

.education-degree {
  font-family: var(--font-display);
  font-size: var(--text-lg);
  font-weight: 700;
  letter-spacing: -0.015em;
  margin-bottom: var(--space-1);
}

.education-school {
  font-size: var(--text-sm);
  font-weight: 500;
  margin-bottom: var(--space-2);
}

.education-content p { font-size: var(--text-sm); }

/* CTA */
.cta-section { background: transparent; }

.cta-box {
  overflow: hidden;
  padding: var(--space-12);
  text-align: center;
}

.cta-inner { position: relative; z-index: 1; }

.cta-box h2 {
  font-family: var(--font-display);
  font-size: var(--text-2xl);
  font-weight: 800;
  letter-spacing: -0.025em;
  margin-bottom: var(--space-3);
}

.cta-box p {
  max-width: 480px;
  margin-inline: auto;
  margin-bottom: var(--space-8);
}

.cta-actions {
  display: flex;
  gap: var(--space-3);
  justify-content: center;
  flex-wrap: wrap;
}

/* Responsive */
@media (max-width: 1024px) {
  .values-layout { grid-template-columns: 1fr; gap: var(--space-8); }
  .testimonials-grid { grid-template-columns: 1fr 1fr; }
}

@media (max-width: 768px) {
  .hero-layout { grid-template-columns: 1fr; }
  .hero-portrait { order: -1; max-width: 280px; margin-inline: auto; }
  .timeline-item { grid-template-columns: 60px 1fr; gap: var(--space-4); }
  .timeline-item:not(:last-child) .year-line { left: 59px; }
  .values-list { grid-template-columns: 1fr; }
  .testimonials-grid { grid-template-columns: 1fr; }
}
</style>
