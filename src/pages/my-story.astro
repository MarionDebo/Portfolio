---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import portrait from '../assets/portrait-Marion.jpg';

const timeline = [
  {
    year: '2017',
    title: 'Started as a data analyst',
    body: 'I fell into data by accident — economics degree, a startup internship, and suddenly I was the person everyone asked when the numbers didn\'t add up. I discovered I cared less about the numbers themselves and more about the decisions they enabled.',
  },
  {
    year: '2019',
    title: 'Moved into product',
    body: 'A PM at my company left mid-sprint. I raised my hand. Two weeks later I was running discovery sessions and writing specs. It turned out that understanding the data was a superpower in product — I could validate assumptions faster than anyone on the team.',
  },
  {
    year: '2021',
    title: 'Led my first AI feature',
    body: 'We were building an anomaly detection system. I pushed the team to go further than flagging — to also explain. That was my first real lesson in AI product design: the model is rarely the bottleneck. The user\'s trust is.',
  },
  {
    year: '2022',
    title: 'Rebuilt onboarding from scratch',
    body: 'Time-to-value was killing us. I ran a six-week redesign sprint that cut 34 steps from the onboarding flow and moved completion rates from 12% to 71%. I learned that the best product decision is often removing something, not adding it.',
  },
  {
    year: '2023',
    title: 'Shipped the embedded analytics SDK',
    body: 'This was the most technically complex product I\'ve led — a white-label analytics SDK adopted by 40+ enterprise clients. It forced me to think like a platform PM: every API decision is a contract you\'ll be maintaining for years.',
  },
  {
    year: '2024',
    title: 'Natural language meets the data layer',
    body: 'Shipped a production LLM interface on top of a multi-tenant analytics stack. 800+ evaluation queries. A trust model. A 60% reduction in time-to-insight. And a genuine belief that AI in analytics is still in its first chapter.',
  },
];

const testimonials = [
  {
    quote: "Marion is the rare PM who can walk into a data engineering stand-up and immediately contribute. She understands the trade-offs, asks the right questions, and never pretends ambiguity away. Working with her changed how our whole team approaches discovery.",
    name: 'Julien M.',
    role: 'Engineering Lead, analytics platform',
    initials: 'JM',
  },
  {
    quote: "She's got an exceptional ability to hold both the strategic picture and the user-level detail at the same time. Our NPS jumped 18 points after she led the AI query feature — and she knew exactly why before the survey came back.",
    name: 'Sofia K.',
    role: 'Head of Product, B2B SaaS',
    initials: 'SK',
  },
  {
    quote: "Marion rebuilt our onboarding from the ground up in six weeks. What stands out isn't just the result — it's how she got there. Every decision was tied to evidence, every trade-off was communicated clearly, and the team was energised throughout.",
    name: 'Thomas R.',
    role: 'CEO, early-stage data startup',
    initials: 'TR',
  },
];
---

<BaseLayout
  title="My Story — Marion"
  description="From data analyst to AI product manager — the decisions, pivots, and lessons that shaped my approach to building data products."
>
  <!-- Hero -->
  <section class="story-hero">
    <div class="container hero-layout">
      <div class="hero-text">
        <div class="breadcrumb text-muted">
          <a href="/">Home</a>
          <span aria-hidden="true">›</span>
          <span>My Story</span>
        </div>

        <h1 class="page-title">
          The long way<br />
          <span class="text-gradient">into AI product</span>
        </h1>

        <p class="page-sub text-muted">
          I didn't plan to become a PM. I started by understanding data better than most,
          then learned that understanding users was the harder and more interesting problem.
          Seven years later, I sit at the intersection of both — and that's exactly where I want to be.
        </p>

        <div class="hero-chips">
          <span class="tag accent">Product Management</span>
          <span class="tag accent">AI-native</span>
          <span class="tag accent">Embedded Analytics</span>
          <span class="tag">B2B SaaS</span>
          <span class="tag">Based in Paris 🇫🇷</span>
        </div>
      </div>

      <div class="hero-portrait">
        <div class="portrait-wrap">
          <Image
            src={portrait}
            alt="Marion, Product Manager specialised in AI and analytics"
            width={420}
            height={500}
            class="portrait-img"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="timeline-section">
    <div class="container">
      <h2 class="section-title">The journey</h2>
      <p class="section-sub text-muted">
        Not a CV. A sequence of decisions — the ones that stuck, the ones that surprised me,
        and what I learned from each.
      </p>

      <div class="timeline" role="list">
        {timeline.map((item, i) => (
          <div class="timeline-item" role="listitem">
            <div class="timeline-year">
              <span class="year-label">{item.year}</span>
              <div class="year-line" aria-hidden="true"></div>
            </div>
            <div class="timeline-content card">
              <h3 class="timeline-title">{item.title}</h3>
              <p class="text-muted">{item.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What drives me -->
  <section class="values-section">
    <div class="container">
      <div class="values-layout">
        <div class="values-header">
          <h2 class="section-title">What I believe about product</h2>
        </div>
        <div class="values-list">
          {[
            { label: 'Evidence over opinion', text: 'I can hold a strong view while remaining genuinely open to being wrong. The data decides, not the loudest voice in the room.' },
            { label: 'Trust is a product feature', text: 'Especially in AI. If users can\'t tell when to trust the system, you haven\'t shipped a feature — you\'ve shipped uncertainty.' },
            { label: 'Simplicity is the hard part', text: 'Anyone can add. Removing something that\'s used by 15% of users but confuses 85% takes courage. That\'s the PM job.' },
            { label: 'Know the stack', text: 'I won\'t write the query, but I\'ll understand why it\'s slow. That fluency makes me a better partner to engineers and a faster decision-maker.' },
          ].map(v => (
            <div class="value-item">
              <h3 class="value-label">{v.label}</h3>
              <p class="text-muted">{v.text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="testimonials-section">
    <div class="container">
      <h2 class="section-title">Kind words from teammates</h2>
      <p class="section-sub text-muted">From people I've shipped with.</p>

      <div class="testimonials-grid">
        {testimonials.map(t => (
          <figure class="card testimonial-card">
            <div class="quote-mark" aria-hidden="true">"</div>
            <blockquote class="testimonial-quote">
              {t.quote}
            </blockquote>
            <figcaption class="testimonial-author">
              <div class="author-avatar" aria-hidden="true">{t.initials}</div>
              <div>
                <p class="author-name">{t.name}</p>
                <p class="author-role text-muted">{t.role}</p>
              </div>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="card cta-box">
        <div class="cta-glow" aria-hidden="true"></div>
        <div class="cta-inner">
          <h2>Let's write the next chapter together</h2>
          <p class="text-muted">
            If you're building something at the intersection of AI, data, and product —
            I'd genuinely love to hear about it.
          </p>
          <div class="cta-actions">
            <a href="mailto:hello@marionpm.com" class="btn btn-primary">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"/></svg>
              Say hello
            </a>
            <a href="/portfolio" class="btn btn-outline">See my work</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
/* Hero */
.story-hero {
  padding-top: calc(var(--space-20) + var(--space-8));
  padding-bottom: var(--space-16);
  background: var(--color-bg-surface);
}

.hero-layout {
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: var(--space-16);
  align-items: center;
}

.breadcrumb {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--text-sm);
  margin-bottom: var(--space-6);
}
.breadcrumb a:hover { color: var(--color-text); }

.page-title {
  font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
  font-weight: 700;
  letter-spacing: -0.03em;
  line-height: var(--leading-tight);
  margin-bottom: var(--space-6);
}

.page-sub {
  font-size: var(--text-lg);
  max-width: 520px;
  line-height: var(--leading-normal);
  margin-bottom: var(--space-8);
}

.hero-chips {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
}

/* Portrait */
.portrait-wrap {
  border-radius: var(--radius-xl);
  overflow: hidden;
  aspect-ratio: 4/5;
  box-shadow: var(--shadow-card), 0 0 60px rgba(124,106,247,0.1);
}

.portrait-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: top center;
}

/* Timeline */
.timeline-section { background: var(--color-bg); }

.section-title {
  font-size: var(--text-3xl);
  font-weight: 700;
  letter-spacing: -0.02em;
  margin-bottom: var(--space-3);
}

.section-sub {
  font-size: var(--text-lg);
  max-width: 560px;
  margin-bottom: var(--space-12);
}

.timeline {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.timeline-item {
  display: grid;
  grid-template-columns: 100px 1fr;
  gap: var(--space-8);
  position: relative;
}

.timeline-item:not(:last-child) .year-line {
  position: absolute;
  left: 99px;
  top: var(--space-12);
  bottom: 0;
  width: 1px;
  background: var(--color-border);
}

.timeline-year {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  padding-top: var(--space-8);
  flex-shrink: 0;
  position: relative;
}

.year-label {
  font-size: var(--text-sm);
  font-weight: 700;
  font-family: var(--font-mono);
  color: var(--color-accent);
  background: var(--color-bg);
  padding: var(--space-1) 0;
  position: relative;
  z-index: 1;
}

.timeline-content {
  margin-block: var(--space-4);
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.timeline-title {
  font-size: var(--text-lg);
  font-weight: 600;
  letter-spacing: -0.01em;
}

.timeline-content p { font-size: var(--text-base); }

/* Values */
.values-section { background: var(--color-bg-surface); }

.values-layout {
  display: grid;
  grid-template-columns: 240px 1fr;
  gap: var(--space-16);
  align-items: start;
}

.values-header .section-title { margin-bottom: 0; }

.values-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-8);
}

.value-label {
  font-size: var(--text-base);
  font-weight: 600;
  margin-bottom: var(--space-2);
  color: var(--color-text);
}

.value-item p { font-size: var(--text-sm); }

/* Testimonials */
.testimonials-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-6);
}

.testimonial-card {
  display: flex;
  flex-direction: column;
  gap: var(--space-6);
  position: relative;
  overflow: hidden;
}

.quote-mark {
  font-size: 4rem;
  line-height: 1;
  color: var(--color-accent);
  opacity: 0.4;
  font-family: Georgia, serif;
  margin-bottom: calc(-1 * var(--space-4));
}

.testimonial-quote {
  font-size: var(--text-base);
  line-height: var(--leading-normal);
  color: var(--color-text-muted);
  font-style: italic;
  flex: 1;
}

.testimonial-author {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  padding-top: var(--space-4);
  border-top: 1px solid var(--color-border);
}

.author-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: var(--color-accent-grad);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--text-xs);
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
}

.author-name {
  font-size: var(--text-sm);
  font-weight: 600;
}

.author-role {
  font-size: var(--text-xs);
}

/* CTA */
.cta-box {
  position: relative;
  overflow: hidden;
  padding: var(--space-12);
  text-align: center;
}

.cta-glow {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 50% 50%, rgba(124,106,247,0.1) 0%, transparent 60%);
}

.cta-inner { position: relative; z-index: 1; }

.cta-box h2 {
  font-size: var(--text-2xl);
  font-weight: 700;
  letter-spacing: -0.02em;
  margin-bottom: var(--space-3);
}

.cta-box p {
  max-width: 480px;
  margin-inline: auto;
  margin-bottom: var(--space-8);
}

.cta-actions {
  display: flex;
  gap: var(--space-3);
  justify-content: center;
  flex-wrap: wrap;
}

/* Responsive */
@media (max-width: 1024px) {
  .values-layout { grid-template-columns: 1fr; gap: var(--space-8); }
  .testimonials-grid { grid-template-columns: 1fr 1fr; }
}

@media (max-width: 768px) {
  .hero-layout { grid-template-columns: 1fr; }
  .hero-portrait { order: -1; max-width: 300px; margin-inline: auto; }

  .timeline-item { grid-template-columns: 60px 1fr; gap: var(--space-4); }
  .timeline-item:not(:last-child) .year-line { left: 59px; }

  .values-list { grid-template-columns: 1fr; }
  .testimonials-grid { grid-template-columns: 1fr; }
}
</style>
