---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('portfolio');
const projects = allProjects.sort((a, b) => a.data.order - b.data.order);
const featured  = projects.filter(p => p.data.featured);
const others    = projects.filter(p => !p.data.featured);

const allTags = [...new Set(projects.flatMap(p => p.data.tags))].sort();
---

<BaseLayout
  title="Work — Marion Dupont"
  description="Product case studies: AI-native analytics, embedded BI, self-serve onboarding, and LLM product integration."
>
  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <div class="breadcrumb text-muted">
        <a href="/">Home</a>
        <span aria-hidden="true">›</span>
        <span>Work</span>
      </div>
      <h1 class="page-title">
        Work that<br />
        <em class="title-em">moved the needle</em>
      </h1>
      <p class="page-sub text-muted">
        A selection of product case studies — each one a real problem, a defined decision,
        and a measurable outcome. No vanity metrics, no slide-deck abstractions.
      </p>

      <!-- Tag filter -->
      <div class="tag-filter" role="group" aria-label="Filter projects by tag">
        <button class="tag tag-btn active" data-tag="all">All</button>
        {allTags.map(tag => (
          <button class="tag tag-btn" data-tag={tag}>{tag}</button>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured projects -->
  <section class="featured-section">
    <div class="container">
      <h2 class="subsection-label text-muted">Featured</h2>

      <div class="featured-grid" id="project-grid">
        {featured.map(project => (
          <article class="card project-card featured" data-tags={project.data.tags.join(',')}>
            <div class="project-header">
              <div class="project-meta">
                {project.data.tags.map(tag => (
                  <span class="tag accent">{tag}</span>
                ))}
                <span class="project-year text-muted">{project.data.year}</span>
              </div>
            </div>

            <h3 class="project-title">{project.data.title}</h3>
            <p class="text-muted project-desc">{project.data.description}</p>

            <div class="project-impact">
              <span class="impact-icon" aria-hidden="true">↗</span>
              <span class="impact-text">{project.data.impact}</span>
            </div>

            <div class="project-footer">
              <a href={`/portfolio/${project.slug}`} class="btn btn-outline btn-sm">
                Read case study
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Other projects -->
  {others.length > 0 && (
    <section class="others-section">
      <div class="container">
        <h2 class="subsection-label text-muted">More projects</h2>

        <div class="others-grid">
          {others.map(project => (
            <article class="card project-card" data-tags={project.data.tags.join(',')}>
              <div class="project-meta">
                {project.data.tags.map(tag => (
                  <span class="tag">{tag}</span>
                ))}
                <span class="project-year text-muted">{project.data.year}</span>
              </div>

              <h3 class="project-title project-title--sm">{project.data.title}</h3>
              <p class="text-muted project-desc project-desc--sm">{project.data.description}</p>

              <div class="project-impact">
                <span class="impact-icon" aria-hidden="true">↗</span>
                <span class="impact-text">{project.data.impact}</span>
              </div>

              <a href={`/portfolio/${project.slug}`} class="project-link-overlay" aria-label={`Read ${project.data.title}`}></a>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Process section -->
  <section class="process-section">
    <div class="container">
      <div class="process-layout">
        <div class="process-header">
          <h2 class="section-title">How I work</h2>
          <p class="text-muted">
            Every project above followed a version of this loop — adapted to the
            constraints, but never skipping the fundamentals.
          </p>
        </div>

        <ol class="process-steps" role="list">
          {[
            { step: '01', title: 'Frame the problem', desc: 'Who has the pain? What are they actually trying to do? Where does the current solution break down?' },
            { step: '02', title: 'Map the opportunity', desc: 'What would success look like in 12 months? What evidence would tell us we got it right?' },
            { step: '03', title: 'Decide fast, cheaply', desc: 'Prototype the riskiest assumption first. Run a test, not a meeting.' },
            { step: '04', title: 'Ship with a truth metric', desc: 'Every launch has a defined "this worked / this didn\'t" threshold, agreed before we ship.' },
          ].map(s => (
            <li class="process-step">
              <span class="step-number text-muted">{s.step}</span>
              <div>
                <h3 class="step-title">{s.title}</h3>
                <p class="text-muted step-desc">{s.desc}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <div class="card cta-box">
        <div class="cta-inner">
          <h2>Have a hard data product problem?</h2>
          <p class="text-muted">Let's see if I can help.</p>
          <a href="mailto:hello@mariondupont.com" class="btn btn-primary">Get in touch</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
/* Hero */
.page-hero {
  padding-top: calc(var(--space-20) + var(--space-8));
  padding-bottom: var(--space-12);
}

.breadcrumb {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--text-sm);
  margin-bottom: var(--space-6);
}
.breadcrumb a:hover { color: var(--color-text); }

.page-title {
  font-family: var(--font-display);
  font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
  font-weight: 800;
  letter-spacing: -0.03em;
  line-height: var(--leading-tight);
  margin-bottom: var(--space-6);
}

.title-em {
  font-style: italic;
  font-weight: 300;
  color: var(--color-accent);
}

.page-sub {
  font-size: var(--text-lg);
  max-width: 560px;
  margin-bottom: var(--space-8);
}

/* Tag filter */
.tag-filter {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
}

.tag-btn {
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  border: 1.5px solid var(--glass-border);
  color: var(--color-text-muted);
  font-family: inherit;
  font-size: var(--text-xs);
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-full);
  cursor: pointer;
  transition: all var(--transition);
}

.tag-btn:hover,
.tag-btn.active {
  border-color: var(--color-accent);
  color: var(--color-accent);
  background: var(--color-accent-light);
}

/* Section labels */
.subsection-label {
  font-size: var(--text-xs);
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  margin-bottom: var(--space-6);
}

/* Featured grid */
.featured-section { background: rgba(255,255,255,0.28); }

.featured-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-6);
}

/* Others grid */
.others-section { background: transparent; }

.others-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--space-6);
}

/* Project card */
.project-card {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
  position: relative;
  transition: border-color var(--transition), transform var(--transition);
}

.project-card:hover { transform: translateY(-2px); }
.project-card.hidden { display: none; }

.project-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.project-meta {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  align-items: center;
}

.project-year { font-size: var(--text-xs); }

.project-title {
  font-family: var(--font-display);
  font-size: var(--text-xl);
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: var(--leading-tight);
}

.project-title--sm { font-size: var(--text-lg); }

.project-desc { font-size: var(--text-sm); line-height: var(--leading-normal); }
.project-desc--sm { font-size: var(--text-sm); }

.project-impact {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-3) var(--space-4);
  background: var(--color-accent-light);
  border: 1px solid var(--color-accent-mid);
  border-radius: var(--radius-md);
  margin-top: auto;
}

.impact-icon { color: var(--color-accent); font-size: var(--text-lg); font-weight: 700; }
.impact-text { font-size: var(--text-sm); font-weight: 600; color: var(--color-accent); }

.project-footer { margin-top: var(--space-2); }

.btn-sm {
  padding: 0.45rem 0.9rem;
  font-size: var(--text-xs);
}

.project-link-overlay {
  position: absolute;
  inset: 0;
  border-radius: inherit;
  z-index: 0;
}

/* Process */
.process-section { background: rgba(255,255,255,0.28); }

.process-layout {
  display: grid;
  grid-template-columns: 260px 1fr;
  gap: var(--space-16);
  align-items: start;
}

.section-title {
  font-family: var(--font-display);
  font-size: var(--text-3xl);
  font-weight: 800;
  letter-spacing: -0.025em;
  margin-bottom: var(--space-4);
}

.process-header .section-title { margin-bottom: var(--space-4); }

.process-steps {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.process-step {
  display: flex;
  gap: var(--space-6);
  align-items: flex-start;
  padding-block: var(--space-6);
  border-bottom: 1px solid var(--color-border-soft);
}

.process-step:last-child { border-bottom: none; }

.step-number {
  font-size: var(--text-xs);
  font-weight: 600;
  font-family: var(--font-mono);
  padding-top: 3px;
  flex-shrink: 0;
  width: 28px;
}

.step-title {
  font-size: var(--text-base);
  font-weight: 600;
  margin-bottom: var(--space-1);
}

.step-desc { font-size: var(--text-sm); }

/* CTA */
.cta-section { background: transparent; }

.cta-box {
  overflow: hidden;
  padding: var(--space-12);
  text-align: center;
}

.cta-inner { position: relative; z-index: 1; }

.cta-box h2 {
  font-family: var(--font-display);
  font-size: var(--text-2xl);
  font-weight: 800;
  letter-spacing: -0.025em;
  margin-bottom: var(--space-3);
}

.cta-box p { margin-bottom: var(--space-6); }

/* Responsive */
@media (max-width: 1024px) {
  .featured-grid { grid-template-columns: repeat(2, 1fr); }
  .process-layout { grid-template-columns: 1fr; gap: var(--space-8); }
}

@media (max-width: 768px) {
  .featured-grid  { grid-template-columns: 1fr; }
  .others-grid    { grid-template-columns: 1fr; }
}
</style>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
  const cards   = document.querySelectorAll<HTMLElement>('.project-card');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag ?? 'all';
      buttons.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      cards.forEach(card => {
        if (tag === 'all') {
          card.classList.remove('hidden');
        } else {
          const cardTags = (card.dataset.tags ?? '').split(',');
          card.classList.toggle('hidden', !cardTags.includes(tag));
        }
      });
    });
  });
</script>
