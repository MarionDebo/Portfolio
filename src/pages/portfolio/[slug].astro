---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('portfolio');
  return projects.map(p => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const project  = await getEntry('portfolio', slug!);
if (!project) return Astro.redirect('/portfolio');

const { Content } = await project.render();
const { title, description, year, tags, impact } = project.data;
---

<BaseLayout title={`${title} — Marion`} description={description}>
  <section class="case-hero">
    <div class="container">
      <div class="breadcrumb text-muted">
        <a href="/">Home</a>
        <span aria-hidden="true">›</span>
        <a href="/portfolio">Portfolio</a>
        <span aria-hidden="true">›</span>
        <span>{title}</span>
      </div>

      <div class="case-meta">
        {tags.map(tag => <span class="tag accent">{tag}</span>)}
        <span class="text-muted" style="font-size:var(--text-sm)">{year}</span>
      </div>

      <h1 class="case-title">{title}</h1>
      <p class="case-lead text-muted">{description}</p>

      <div class="impact-banner">
        <span class="impact-icon" aria-hidden="true">↗</span>
        <span class="impact-text">{impact}</span>
      </div>
    </div>
  </section>

  <section class="case-body">
    <div class="container case-layout">
      <article class="prose">
        <Content />
      </article>

      <aside class="case-sidebar">
        <div class="sidebar-card card">
          <h3 class="sidebar-title">At a glance</h3>
          <dl class="sidebar-dl">
            <div><dt>Year</dt><dd>{year}</dd></div>
            <div><dt>Impact</dt><dd>{impact}</dd></div>
            <div>
              <dt>Tags</dt>
              <dd class="tag-list">
                {tags.map(tag => <span class="tag">{tag}</span>)}
              </dd>
            </div>
          </dl>
        </div>

        <a href="/portfolio" class="btn btn-outline back-btn">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          All projects
        </a>

        <a href="mailto:hello@marionpm.com" class="btn btn-primary">
          Discuss this project
        </a>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
.case-hero {
  padding-top: calc(var(--space-20) + var(--space-8));
  padding-bottom: var(--space-16);
  background: var(--color-bg-surface);
  border-bottom: 1px solid var(--color-border);
}

.breadcrumb {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  font-size: var(--text-sm);
  margin-bottom: var(--space-6);
}
.breadcrumb a:hover { color: var(--color-text); }

.case-meta {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  margin-bottom: var(--space-4);
  flex-wrap: wrap;
}

.case-title {
  font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
  font-weight: 700;
  letter-spacing: -0.03em;
  line-height: var(--leading-tight);
  margin-bottom: var(--space-6);
}

.case-lead {
  font-size: var(--text-xl);
  max-width: 640px;
  line-height: var(--leading-normal);
  margin-bottom: var(--space-8);
}

.impact-banner {
  display: inline-flex;
  align-items: center;
  gap: var(--space-3);
  padding: var(--space-3) var(--space-6);
  border-radius: var(--radius-md);
  background: rgba(124,106,247,0.08);
  border: 1px solid rgba(124,106,247,0.2);
}

.impact-icon {
  color: var(--color-accent);
  font-size: var(--text-xl);
  font-weight: 700;
}

.impact-text {
  font-size: var(--text-base);
  font-weight: 600;
  color: var(--color-accent);
}

/* Body */
.case-body { padding-block: var(--space-16); }

.case-layout {
  display: grid;
  grid-template-columns: 1fr 300px;
  gap: var(--space-16);
  align-items: start;
}

/* Prose */
.prose {
  color: var(--color-text);
  line-height: var(--leading-normal);
  max-width: 680px;
}

.prose :global(h2) {
  font-size: var(--text-2xl);
  font-weight: 700;
  letter-spacing: -0.02em;
  margin-top: var(--space-12);
  margin-bottom: var(--space-4);
  padding-bottom: var(--space-3);
  border-bottom: 1px solid var(--color-border);
}

.prose :global(h3) {
  font-size: var(--text-xl);
  font-weight: 600;
  margin-top: var(--space-8);
  margin-bottom: var(--space-3);
}

.prose :global(p) {
  color: var(--color-text-muted);
  margin-bottom: var(--space-4);
  font-size: var(--text-lg);
}

.prose :global(ul), .prose :global(ol) {
  padding-left: var(--space-6);
  margin-bottom: var(--space-4);
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

.prose :global(li) {
  color: var(--color-text-muted);
  font-size: var(--text-lg);
}

.prose :global(strong) { color: var(--color-text); font-weight: 600; }

.prose :global(code) {
  font-family: var(--font-mono);
  font-size: 0.875em;
  background: rgba(255,255,255,0.06);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  padding: 0.1em 0.4em;
}

/* Sidebar */
.case-sidebar {
  position: sticky;
  top: calc(var(--nav-height) + var(--space-6));
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.sidebar-card { padding: var(--space-6); }

.sidebar-title {
  font-size: var(--text-sm);
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--color-text-muted);
  margin-bottom: var(--space-4);
}

.sidebar-dl {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.sidebar-dl dt {
  font-size: var(--text-xs);
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--color-text-faint);
  margin-bottom: var(--space-1);
}

.sidebar-dl dd {
  font-size: var(--text-sm);
  color: var(--color-text);
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-1);
}

.back-btn, .btn-primary {
  width: 100%;
  justify-content: center;
}

/* Responsive */
@media (max-width: 900px) {
  .case-layout {
    grid-template-columns: 1fr;
  }
  .case-sidebar {
    position: static;
    order: -1;
  }
}
</style>
