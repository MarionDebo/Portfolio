---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/sections/ProjectCard.astro';
import BrowserMock from '../components/sections/BrowserMock.astro';
import PhoneMock from '../components/sections/PhoneMock.astro';
import dashboardShot from '../assets/images/projects/self-service-dashboard.png';
---

<BaseLayout title="Work — Marion Débonnaire" bg="white">
  <!-- ░░ Header ░░ -->
  <section class="work-header gradient-hero nav-bleed">
    <div class="header-inner">
      <h1>Selected Work</h1>
      <p class="lead">Three products at the intersection of AI, data and human experience, from conversational analytics to a social-impact mobile platform. Each one a different problem, the same way of working.</p>
      <div class="stats">
        <div class="stat"><div class="num">03</div>CASE STUDIES</div>
      </div>
    </div>
  </section>

  <!-- ░░ Project 01 · Toucan AI ░░ -->
  <ProjectCard
    index="01"
    tags={['AI', 'Conversational UX']}
    title="Toucan AI"
    blurb="An AI-native, conversational analytics platform, rebuilt from scratch so end users can simply ask a question and instantly get the answer."
    metricValue="15+ qualified opportunities"
    metricSuffix="in the first month of beta"
    href="/portfolio/toucan-ai"
    asLink
    bg="#FFFFFF"
    hoverBg="#FAF9FE"
  >
    <BrowserMock slot="media" variant="chart" />
  </ProjectCard>

  <!-- ░░ Project 02 · Entourage ░░ -->
  <ProjectCard
    index="02"
    tags={['Mobile', 'Social Impact']}
    title="Entourage App Redesign"
    blurb="Repositioning a non-profit's app from donation-centric to a social connection platform built around events, communities and education."
    metricValue="170,000 users"
    metricSuffix="on the app"
    href="#"
    asLink
    reverse
    bg="#ECE7FF"
    hoverBg="#E4DBFF"
  >
    <PhoneMock slot="media" />
  </ProjectCard>

  <!-- ░░ Project 03 · Self-service Dashboard ░░ -->
  <ProjectCard
    index="03"
    tags={['B2B SaaS', 'Acquisition']}
    title="Self-service Dashboard"
    blurb="A pick-and-choose dashboard editor that lets business users customize their embedded analytics, with no technical knowledge required."
    metricValue="36% of SQL-to-QSO conversions"
    metricSuffix="in 2025"
    href="/portfolio/self-service-dashboard"
    asLink
    bg="#F4F2EE"
    hoverBg="#EDEAE3"
  >
    <BrowserMock slot="media" soft urlWidth="40%">
      <Image src={dashboardShot} alt="Toucan self-service dashboard editor" widths={[480, 720, 960]} sizes="(max-width: 860px) 90vw, 600px" />
    </BrowserMock>
  </ProjectCard>
</BaseLayout>

<style>
.header-inner {
  max-width: var(--max-nav);
  margin: 0 auto;
  padding: 72px var(--gutter) 64px;
}
.work-header h1 {
  font-size: 72px;
  font-weight: 600;
  line-height: 1.02;
  letter-spacing: -0.03em;
  margin: 0 0 26px;
  color: var(--color-ink);
}
.lead {
  font-size: 20px;
  line-height: 1.6;
  color: var(--color-muted);
  max-width: 54ch;
  margin: 0;
}
.stats {
  display: flex;
  gap: 40px;
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--color-meta);
  border-top: 1px solid rgba(21, 19, 28, 0.14);
  padding-top: 24px;
  margin-top: 44px;
}
.stat .num {
  font-family: var(--font-display);
  font-size: 30px;
  font-weight: 600;
  letter-spacing: -0.02em;
  color: var(--color-ink);
}

@media (max-width: 640px) {
  .work-header h1 { font-size: clamp(44px, 12vw, 72px); }
  .header-inner { padding: 56px var(--gutter) 48px; }
}
</style>
